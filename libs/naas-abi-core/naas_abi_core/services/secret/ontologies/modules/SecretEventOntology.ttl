@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix abi: <http://ontology.naas.ai/abi/> .
@prefix secret: <http://ontology.naas.ai/abi/secret/> .

secret:SecretEventOntology a owl:Ontology ;
  dc:title "Secret Event Ontology"@en ;
  dc:description "Events emitted by the SecretService when secrets are written, removed, or fail to mutate. Secret values are never included in events."@en ;
  dc:license <https://creativecommons.org/licenses/by/4.0/> ;
  owl:imports <http://ontology.naas.ai/abi/EventService> ;
  abi:pythonPackage    "naas_abi_core.services.secret" ;
  abi:ontologyResource "ontologies/modules/SecretEventOntology.ttl" ;
  abi:pythonResource   "ontologies/modules/SecretEventOntology.py" ;
  dc11:date "2026-05-27"^^xsd:date .

# SecretSet: published after a successful set(key, value) across all adapters.
secret:SecretSet a owl:Class ;
    rdfs:label "SecretSet"@en ;
    rdfs:subClassOf abi:LogProcess ;
    skos:definition "An event recorded when a secret is successfully written. Never carries the secret value."@en .

# SecretRemoved: published after a successful remove(key) across all adapters.
secret:SecretRemoved a owl:Class ;
    rdfs:label "SecretRemoved"@en ;
    rdfs:subClassOf abi:LogProcess ;
    skos:definition "An event recorded when a secret is successfully removed."@en .

# SecretError: published when a secret mutation against an adapter raises.
secret:SecretError a owl:Class ;
    rdfs:label "SecretError"@en ;
    rdfs:subClassOf abi:LogProcess ;
    skos:definition "An event recorded when a secret mutation (set/remove) raises an exception."@en .

secret:key a owl:DatatypeProperty ;
    rdfs:label "key"@en ;
    rdfs:domain secret:SecretSet, secret:SecretRemoved, secret:SecretError ;
    rdfs:range xsd:string ;
    skos:definition "Secret key the operation targeted."@en .

secret:operation a owl:DatatypeProperty ;
    rdfs:label "operation"@en ;
    rdfs:domain secret:SecretError ;
    rdfs:range xsd:string ;
    skos:definition "Name of the secret operation that failed (e.g. 'set', 'remove')."@en .

secret:message a owl:DatatypeProperty ;
    rdfs:label "message"@en ;
    rdfs:domain secret:SecretError ;
    rdfs:range xsd:string ;
    skos:definition "String representation of the exception raised by the adapter."@en .
