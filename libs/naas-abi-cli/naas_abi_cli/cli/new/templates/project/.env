# Project secrets and environment variables.
# Resolved by the `secret` service when config files reference {% raw %}{{ secret.X }}{% endraw %}.
# Add provider API keys, tokens, and other secrets below.

# Base domain for this project. PUBLIC_WEB_HOST and PUBLIC_API_HOST are derived
# from this (nexus.<domain> and api.<domain>). Override either if you don't want
# the derived value.
BASE_DOMAIN={{base_domain}}
PUBLIC_WEB_HOST={{public_web_host}}
PUBLIC_API_HOST={{public_api_host}}
