@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix abi: <http://ontology.naas.ai/abi/> .

<http://ontology.naas.ai/abi/TimeOntology> rdf:type owl:Ontology ;
    owl:imports <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.ttl>  ;
    dc:title "Person Ontology"@en ;
    dc:description "Ontology for time."@en ;
    dc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Creating specific classes for time."@en ;
    dc11:contributor "Florent Ravenel", "Jeremy Ravenel", "Maxime Jublou" ;
    dc11:date "2025-06-10"^^xsd:date .

#################################################################
#    Classes
#################################################################

abi:ISO8601UTCDateTime a owl:Class ;
    rdfs:subClassOf bfo:BFO_0000203 ; # Temporal instant
    rdfs:label "ISO 8601 UTC DateTime" ;
    skos:definition "A Temporal Instant specified according to the ISO 8601 standard format with UTC timezone, representing a specific point in time." ;
    skos:example "2025-01-01T00:00:00.000Z" .