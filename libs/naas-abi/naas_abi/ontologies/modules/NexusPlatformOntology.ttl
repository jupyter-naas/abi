nexus:hasOntologyClassRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isOntologyClassRoleOf ;
    rdfs:label "has ontology class role"@en ;
    skos:definition "Relates an ontology class to an ontology class role that concretizes it in platform use."@en ;
    rdfs:domain nexus:OntologyClass ;
