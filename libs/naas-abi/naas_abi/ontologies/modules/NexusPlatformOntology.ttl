    rdfs:range nexus:MarketplaceAppRole .

nexus:isMarketplaceAppRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasMarketplaceAppRole ;
    rdfs:label "is marketplace app role of"@en ;
    skos:definition "Relates a marketplace application role to the marketplace application of which it is the role-side concretization."@en ;
    rdfs:domain nexus:MarketplaceAppRole ;
    rdfs:range nexus:MarketplaceApps .

nexus:usesModel a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000101 ;
    owl:inverseOf nexus:isModelOf ;
    rdfs:label "uses model"@en ;
    skos:definition "Relates an agent to the AI model it uses."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:AIModel .

nexus:isModelOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000084 ;
    owl:inverseOf nexus:usesModel ;
    rdfs:label "is model of"@en ;
    skos:definition "Relates an AI model to the agent that uses it."@en ;
    rdfs:domain nexus:AIModel ;
    rdfs:range nexus:Agent .

nexus:hasProvider a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000084 ;
    rdfs:label "has provider"@en ;
    skos:definition "Relates an AI model to the organization that provides it."@en ;
    rdfs:domain nexus:AIModel ;
    rdfs:range cco:ont00001180 .

nexus:hasCapabilities a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000196 ;
    owl:inverseOf nexus:isCapabilitiesOf ;
    rdfs:label "has capabilities"@en ;
    skos:definition "Relates an organization to a capability it possesses."@en ;
    rdfs:domain cco:ont00001180 ;
    rdfs:range nexus:Capabilities .

nexus:isCapabilitiesOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000197 ;
    owl:inverseOf nexus:hasCapabilities ;
    rdfs:label "is capabilities of"@en ;
    skos:definition "Relates a capability to the organization in which it inheres."@en ;
    rdfs:domain nexus:Capabilities ;
    rdfs:range cco:ont00001180 .

# --- Session / VisitorRole properties (Platform Processes) -------

nexus:hasSession a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000101 ;
    owl:inverseOf nexus:isSessionOf ;
    rdfs:label "has session"@en ;
    skos:definition "Relates a workspace to a session that generically depends on it within the Nexus platform."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:Session .

nexus:isSessionOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000084 ;
    owl:inverseOf nexus:hasSession ;
    rdfs:label "is session of"@en ;
    skos:definition "Relates a session to the workspace on which it generically depends."@en ;
    rdfs:domain nexus:Session ;
    rdfs:range nexus:Workspace .

nexus:hasSessionRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isSessionRoleOf ;
    rdfs:label "has session role"@en ;
    skos:definition "Relates a session to a session role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Session ;
    rdfs:range nexus:SessionRole .

nexus:isSessionRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasSessionRole ;
    rdfs:label "is session role of"@en ;
    skos:definition "Relates a session role to the session of which it is the role-side concretization."@en ;
    rdfs:domain nexus:SessionRole ;
    rdfs:range nexus:Session .

nexus:bearsVisitorRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000196 ;
    owl:inverseOf nexus:isVisitorRoleOf ;
    rdfs:label "bears visitor role"@en ;
    skos:definition "Relates a user to the visitor role it bears when visiting the Nexus platform."@en ;
    rdfs:domain nexus:User ;
    rdfs:range nexus:VisitorRole .

nexus:isVisitorRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000197 ;
    owl:inverseOf nexus:bearsVisitorRole ;
    rdfs:label "is visitor role of"@en ;
    skos:definition "Relates a visitor role to the user in which it inheres."@en ;
    rdfs:domain nexus:VisitorRole ;
    rdfs:range nexus:User .

nexus:initiatesSession a owl:ObjectProperty ;
    owl:inverseOf nexus:isInitiatedByLogin ;
    rdfs:label "initiates session"@en ;
    skos:definition "Relates a login process to the visit session it opens; both processes share the same temporal boundary at session start."@en ;
    rdfs:domain nexus:LoginProcess ;
    rdfs:range nexus:VisitSession .

nexus:isInitiatedByLogin a owl:ObjectProperty ;
    owl:inverseOf nexus:initiatesSession ;
    rdfs:label "is initiated by login"@en ;
    skos:definition "Relates a visit session to the login process that opens it."@en ;
    rdfs:domain nexus:VisitSession ;
    rdfs:range nexus:LoginProcess .

nexus:terminatesSession a owl:ObjectProperty ;
    owl:inverseOf nexus:isTerminatedByLogout ;
    rdfs:label "terminates session"@en ;
    skos:definition "Relates a logout process to the visit session it closes; both processes share the same temporal boundary at session end."@en ;
    rdfs:domain nexus:Logout ;
    rdfs:range nexus:VisitSession .

nexus:isTerminatedByLogout a owl:ObjectProperty ;
    owl:inverseOf nexus:terminatesSession ;
    rdfs:label "is terminated by logout"@en ;
    skos:definition "Relates a visit session to the logout process that closes it."@en ;
    rdfs:domain nexus:VisitSession ;
    rdfs:range nexus:Logout .

nexus:hasPage a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000101 ;
    owl:inverseOf nexus:isPageOf ;
    rdfs:label "has page"@en ;
    skos:definition "Relates a workspace to a navigable page it carries."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:Page .

nexus:isPageOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000084 ;
    owl:inverseOf nexus:hasPage ;
    rdfs:label "is page of"@en ;
    skos:definition "Relates a page to the workspace on which it generically depends."@en ;
    rdfs:domain nexus:Page ;
    rdfs:range nexus:Workspace .

nexus:hasPageRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isPageRoleOf ;
    rdfs:label "has page role"@en ;
    skos:definition "Relates a page to a page role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Page ;
    rdfs:range nexus:PageRole .

nexus:isPageRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasPageRole ;
    rdfs:label "is page role of"@en ;
    skos:definition "Relates a page role to the page of which it is the role-side concretization."@en ;
    rdfs:domain nexus:PageRole ;
    rdfs:range nexus:Page .

nexus:hasLog a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000101 ;
    owl:inverseOf nexus:isLogOf ;
    rdfs:label "has log"@en ;
    skos:definition "Relates a session to a log entry generically dependent on it; one session carries the ordered stream of logs emitted during the visit."@en ;
    rdfs:domain nexus:Session ;
    rdfs:range nexus:Log .

nexus:isLogOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000084 ;
    owl:inverseOf nexus:hasLog ;
    rdfs:label "is log of"@en ;
    skos:definition "Relates a log entry to the session on which it generically depends."@en ;
    rdfs:domain nexus:Log ;
    rdfs:range nexus:Session .

nexus:hasLogRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isLogRoleOf ;
    rdfs:label "has log role"@en ;
    skos:definition "Relates a log entry to a log role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Log ;
    rdfs:range nexus:LogRole .

nexus:isLogRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasLogRole ;
    rdfs:label "is log role of"@en ;
    skos:definition "Relates a log role to the log entry of which it is the role-side concretization."@en ;
    rdfs:domain nexus:LogRole ;
    rdfs:range nexus:Log .


#################################################################
#    Data Properties
#################################################################

nexus:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:domain nexus:Agent, nexus:AgentTool, nexus:AgentIntent, nexus:AgentRole, nexus:KnowledgeGraph, nexus:GraphView;
    rdfs:range xsd:string ;
    skos:definition "A description used in Nexus platform to identify a generically dependent continuant instance."@en ;
    skos:example "Agent used to search for information on the web." .

nexus:logo_url a owl:DatatypeProperty ;
    rdfs:label "logo url"@en ;
    rdfs:domain nexus:Agent, nexus:Workspace ;
    rdfs:range xsd:string ;
    skos:definition "A URL to a logo image used in Nexus platform to identify a generically dependent continuant instance."@en ;
    skos:example "https://example.com/logo.png" .

nexus:class_name a owl:DatatypeProperty ;
    rdfs:label "class name"@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range xsd:string ;
    skos:definition "Agent class name."@en ;
    skos:example "AbiAgent" .

nexus:module_path a owl:DatatypeProperty ;
    rdfs:label "module path"@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range xsd:string ;
    skos:definition "Agent module path in naas-abi."@en ;
    skos:example "naas_abi.agents.AbiAgent" .

nexus:class_path a owl:DatatypeProperty ;
    rdfs:label "class path"@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range xsd:string ;
    skos:definition "Agent module path and class name."@en ;
    skos:example "naas_abi.agents.AbiAgent/AbiAgent" .

nexus:system_prompt a owl:DatatypeProperty ;
    rdfs:label "system prompt"@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range xsd:string ;
    skos:definition "A system prompt used in Nexus platform to configure a software agent."@en ;
    skos:example "You are a helpful assistant that can answer questions and help with tasks." .

nexus:subject_uri a owl:DatatypeProperty ;
    rdfs:label "subject uri"@en ;
    rdfs:domain nexus:GraphFilter ;
    rdfs:range xsd:string ;
    skos:definition "The URI of the subject filtering the graph view."@en ;
    skos:example "http://ontology.naas.ai/abi/3a1c515e-2500-460b-bce2-9a0fdc35354c" .

nexus:predicate_uri a owl:DatatypeProperty ;
    rdfs:label "predicate uri"@en ;
    rdfs:domain nexus:GraphFilter ;
    rdfs:range xsd:string ;
    skos:definition "The URI of the predicate filtering the graph view."@en ;
    skos:example "http://www.w3.org/1999/02/22-rdf-syntax-ns#type", "https://www.w3.org/2000/01/rdf-schema#label" .

nexus:object_uri a owl:DatatypeProperty ;
    rdfs:label "object uri"@en ;
    rdfs:domain nexus:GraphFilter ;
    rdfs:range xsd:string ;
    skos:definition "The URI or literal of the object filtering the graph view."@en ;
    skos:example "http://ontology.naas.ai/nexus/Agent", "John Doe" .

nexus:intent_type a owl:DatatypeProperty ;
    rdfs:label "intent type"@en ;
    rdfs:domain nexus:AgentIntent ;
    rdfs:range xsd:string ;
    skos:definition "The type of the intent."@en ;
    skos:example "RAW", "TOOL", "AGENT" .

nexus:intent_value a owl:DatatypeProperty ;
    rdfs:label "intent value"@en ;
    rdfs:domain nexus:AgentIntent ;
    rdfs:range xsd:string ;
    skos:definition "The value of the intent."@en ;
    skos:example "What can you tell about you?" .

nexus:intent_target a owl:DatatypeProperty ;
    rdfs:label "intent target"@en ;
    rdfs:domain nexus:AgentIntent ;
    rdfs:range xsd:string ;
    skos:definition "The target of the intent."@en ;
    skos:example "I am a software agent developed by Naas.ai" .

nexus:intent_scope a owl:DatatypeProperty ;
    rdfs:label "intent scope"@en ;
    rdfs:domain nexus:AgentIntent ;
    rdfs:range xsd:string ;
    skos:definition "The scope of the intent."@en ;
    skos:example "DIRECT", "INDIRECT" .

nexus:model_id a owl:DatatypeProperty ;
    rdfs:label "model id"@en ;
    rdfs:domain nexus:AIModel ;
    rdfs:range xsd:string ;
    skos:definition "The identifier of the AI model."@en ;
    skos:example "gpt-4.1-mini", "claude-sonnet-4-6" .

# --- Session data properties (Platform Processes) ----------------

nexus:session_id a owl:DatatypeProperty ;
    rdfs:label "session id"@en ;
    rdfs:domain nexus:Session ;
    rdfs:range xsd:string ;
    skos:definition "The unique identifier of a session within the Nexus platform."@en ;
    skos:example "abc123" .

nexus:device a owl:DatatypeProperty ;
    rdfs:label "device"@en ;
    rdfs:domain nexus:Session ;
    rdfs:range xsd:string ;
    skos:definition "The device category from which a session is conducted."@en ;
    skos:example "desktop", "mobile", "tablet" .

nexus:browser a owl:DatatypeProperty ;
    rdfs:label "browser"@en ;
    rdfs:domain nexus:Session ;
    rdfs:range xsd:string ;
    skos:definition "The browser used during a session."@en ;
    skos:example "Chrome", "Safari", "Firefox" .

nexus:country a owl:DatatypeProperty ;
    rdfs:label "country"@en ;
    rdfs:domain nexus:Session ;
    rdfs:range xsd:string ;
    skos:definition "The country code from which a session is conducted."@en ;
    skos:example "FR", "US", "DE" .

# --- VisitSessionInterval / LoginInterval data properties (WHEN) --

nexus:started_at a owl:DatatypeProperty ;
    rdfs:label "started at"@en ;
    rdfs:domain nexus:VisitSessionInterval, nexus:LoginInterval ;
    rdfs:range xsd:dateTime ;
    skos:definition "The opening boundary of a temporal interval; corresponds to the SessionRow.started_at field in the analytics app."@en ;
    skos:example "2026-05-21T10:00:00Z" .

nexus:ended_at a owl:DatatypeProperty ;
    rdfs:label "ended at"@en ;
    rdfs:domain nexus:VisitSessionInterval, nexus:LoginInterval ;
    rdfs:range xsd:dateTime ;
    skos:definition "The closing boundary of a temporal interval; corresponds to the SessionRow.ended_at field in the analytics app."@en ;
    skos:example "2026-05-21T10:22:00Z" .

nexus:duration_seconds a owl:DatatypeProperty ;
    rdfs:label "duration seconds"@en ;
    rdfs:domain nexus:VisitSessionInterval, nexus:LoginInterval ;
    rdfs:range xsd:integer ;
    skos:definition "The size of a temporal interval in seconds; the source quantity behind the avg_session_duration_seconds analytics KPI."@en ;
    skos:example "1320" .

# --- Log data properties (HOW WE KNOW) ---------------------------

nexus:event_id a owl:DatatypeProperty ;
    rdfs:label "event id"@en ;
    rdfs:domain nexus:Log ;
    rdfs:range xsd:string ;
    skos:definition "The unique identifier of a log entry; corresponds to AnalyticsEvent.event_id."@en ;
    skos:example "evt_01HXYZ123" .

nexus:event_name a owl:DatatypeProperty ;
    rdfs:label "event name"@en ;
    rdfs:domain nexus:Log ;
    rdfs:range xsd:string ;
    skos:definition "The categorical name of the event recorded by a log entry; matches the EventName union in the analytics layer."@en ;
    skos:example "login", "logout", "session_started", "page_viewed", "workspace_opened" .

nexus:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp"@en ;
    rdfs:domain nexus:Log ;
    rdfs:range xsd:dateTime ;
    skos:definition "The timestamp at which a log entry was emitted; corresponds to AnalyticsEvent.timestamp."@en ;
    skos:example "2026-05-21T10:00:00Z" .

nexus:page_path a owl:DatatypeProperty ;
    rdfs:label "page path"@en ;
    rdfs:domain nexus:Log, nexus:Page ;
    rdfs:range xsd:string ;
    skos:definition "The path of a page; corresponds to AnalyticsEvent.page_path and Page identity, and feeds the top_pages KPI."@en ;
    skos:example "/analytics", "/workspaces/abc/graph" .

nexus:page_title a owl:DatatypeProperty ;
    rdfs:label "page title"@en ;
    rdfs:domain nexus:Log, nexus:Page ;
    rdfs:range xsd:string ;
    skos:definition "The human-readable title of a page; corresponds to AnalyticsEvent.page_title and the label used in top_pages."@en ;
    skos:example "Nexus Analytics", "Knowledge Graph View" .

nexus:event_payload a owl:DatatypeProperty ;
    rdfs:label "event payload"@en ;
    rdfs:domain nexus:Log ;
    rdfs:range xsd:string ;
    skos:definition "A JSON-encoded payload of structured properties attached to a log entry; corresponds to AnalyticsEvent.properties."@en ;
    skos:example "{\"button\": \"export\", \"format\": \"csv\"}" .

nexus:referrer a owl:DatatypeProperty ;
    rdfs:label "referrer"@en ;
    rdfs:domain nexus:Log ;
    rdfs:range xsd:string ;
    skos:definition "The referring URL recorded with a log entry; corresponds to AnalyticsEvent.referrer."@en ;
    skos:example "https://app.naas.ai/" .

# --- User / Workspace identifier data properties -----------------

nexus:user_id a owl:DatatypeProperty ;
    rdfs:label "user id"@en ;
    rdfs:domain nexus:User ;
    rdfs:range xsd:string ;
    skos:definition "The platform-internal identifier of a user."@en ;
    skos:example "u_alice", "u_bob" .

nexus:email a owl:DatatypeProperty ;
    rdfs:label "email"@en ;
    rdfs:domain nexus:User ;
    rdfs:range xsd:string ;
    skos:definition "The email address of a user."@en ;
    skos:example "alice@example.com" .

nexus:workspace_id a owl:DatatypeProperty ;
    rdfs:label "workspace id"@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range xsd:string ;
    skos:definition "The platform-internal identifier of a workspace."@en ;
    skos:example "ws_main", "ws_research" .

nexus:workspace_name a owl:DatatypeProperty ;
    rdfs:label "workspace name"@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range xsd:string ;
    skos:definition "The display name of a workspace."@en ;
    skos:example "Naas Main", "Research Lab" .