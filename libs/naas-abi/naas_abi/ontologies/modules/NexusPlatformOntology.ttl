@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dc:    <http://purl.org/dc/terms/> .
@prefix dc11:  <http://purl.org/dc/elements/1.1/> .
@prefix bfo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix abi:   <http://ontology.naas.ai/abi/> .
@prefix nexus: <http://ontology.naas.ai/nexus/> .

nexus:PlatformOntology a owl:Ontology ;
  owl:imports <http://ontology.naas.ai/abi/Ontology> ;
  dc:title "Nexus Platform Ontology"@en ;
  dc:description "Ontology for the Nexus platform."@en ;
  dc:license <https://creativecommons.org/licenses/by/4.0/> ;
  rdfs:comment "Ontology for the Nexus platform."@en ;
  dc11:contributor "Florent Ravenel", "Jeremy Ravenel", "Maxime Jublou" ;
  dc11:date "2026-05-22"^^xsd:date .

#################################################################
#    Object Properties
#################################################################

# WHO ↔ HOW WE KNOW — organization carries workspace
nexus:hasWorkspace a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isWorkspaceOf ;
    rdfs:label "has workspace"@en ;
    skos:definition "Relates an organization to a workspace that depends on it within the Nexus platform."@en ;
    rdfs:domain nexus:Organization ;
    rdfs:range nexus:Workspace .

nexus:isWorkspaceOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasWorkspace ;
    rdfs:label "is workspace of"@en ;
    skos:definition "Relates a workspace to the organization on which it generically depends."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:Organization .

# WHO — organization has member user
nexus:hasUser a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasMemberPart ;
    rdfs:label "has user"@en ;
    skos:definition "Relates an organization to a user account that is a member of it in the platform."@en ;
    rdfs:domain nexus:Organization ;
    rdfs:range nexus:User .

# WHO — person carries user account (GDC)
nexus:hasUserAccount a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isUserAccountOf ;
    rdfs:label "has user account"@en ;
    skos:definition "Relates a person to the user account that generically depends on them in the Nexus platform."@en ;
    rdfs:domain abi:Person ;
    rdfs:range nexus:User .

nexus:isUserAccountOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasUserAccount ;
    rdfs:label "is user account of"@en ;
    skos:definition "Relates a user account to the person on which it generically depends."@en ;
    rdfs:domain nexus:User ;
    rdfs:range abi:Person .

# WHO — organization bears tenant role
nexus:hasTenant a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isTenantOf ;
    rdfs:label "has tenant"@en ;
    skos:definition "Relates an organization to the tenant role it bears."@en ;
    rdfs:domain nexus:Organization ;
    rdfs:range nexus:Tenant .

nexus:isTenantOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasTenant ;
    rdfs:label "is tenant of"@en ;
    skos:definition "Relates a tenant role to the organization in which it inheres."@en ;
    rdfs:domain nexus:Tenant ;
    rdfs:range nexus:Organization .

# HOW WE KNOW → WHO — workspace depends on server
nexus:hostedOn a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    rdfs:label "hosted on"@en ;
    skos:definition "Relates a workspace to the physical server on which it depends for hosting."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:Server .

# WHERE — server located in deployment site
nexus:locatedInDeploymentSite a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:locatedIn ;
    rdfs:label "located in deployment site"@en ;
    skos:definition "Relates a server to the deployment site in which it is located."@en ;
    rdfs:domain nexus:Server ;
    rdfs:range nexus:DeploymentSite .

# HOW WE KNOW — workspace carries conversation
nexus:hasConversation a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isConversationOf ;
    rdfs:label "has conversation"@en ;
    skos:definition "Relates a workspace to a conversation it carries or contains."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:Conversation .

nexus:isConversationOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasConversation ;
    rdfs:label "is conversation of"@en ;
    skos:definition "Relates a conversation to the workspace on which it depends."@en ;
    rdfs:domain nexus:Conversation ;
    rdfs:range nexus:Workspace .

# HOW WE KNOW — conversation carries message
nexus:hasMessage a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isMessageOf ;
    rdfs:label "has message"@en ;
    skos:definition "Relates a conversation to a message it contains."@en ;
    rdfs:domain nexus:Conversation ;
    rdfs:range nexus:Message .

nexus:isMessageOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasMessage ;
    rdfs:label "is message of"@en ;
    skos:definition "Relates a message to the conversation on which it depends."@en ;
    rdfs:domain nexus:Message ;
    rdfs:range nexus:Conversation .

# HOW WE KNOW — agent carries intent
nexus:hasAgentIntent a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has intent"@en ;
    skos:definition "Relates an agent to an intent available to it."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:AgentIntent .

nexus:isIntentOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasAgentIntent ;
    rdfs:label "is intent of"@en ;
    skos:definition "Relates an intent to the agent on which it depends."@en ;
    rdfs:domain nexus:AgentIntent ;
    rdfs:range nexus:Agent .

# HOW WE KNOW — agent carries tool
nexus:hasAgentTool a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has tool"@en ;
    skos:definition "Relates an agent to a tool available to it."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:AgentTool .

nexus:isToolOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasAgentTool ;
    rdfs:label "is tool of"@en ;
    skos:definition "Relates a tool to the agent on which it depends."@en ;
    rdfs:domain nexus:AgentTool ;
    rdfs:range nexus:Agent .

# HOW WE KNOW — agent orchestrates sub-agent
nexus:hasSubAgent a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isSubAgentOf ;
    rdfs:label "has sub-agent"@en ;
    skos:definition "Relates a supervisor agent to a sub-agent it orchestrates within the Nexus platform."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:Agent .

nexus:isSubAgentOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasSubAgent ;
    rdfs:label "is sub-agent of"@en ;
    skos:definition "Relates a sub-agent to the supervisor agent that orchestrates it within the Nexus platform."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:Agent .

# HOW WE KNOW — agent carries AI model
nexus:usesModel a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isModelOf ;
    rdfs:label "uses model"@en ;
    skos:definition "Relates an agent to the AI model it uses."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:AIModel .

nexus:isModelOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:usesModel ;
    rdfs:label "is model of"@en ;
    skos:definition "Relates an AI model to the agent that uses it."@en ;
    rdfs:domain nexus:AIModel ;
    rdfs:range nexus:Agent .

# HOW WE KNOW — ontology carries module
nexus:hasOntologyModule a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf nexus:isOntologyModuleOf ;
    rdfs:label "has ontology module"@en ;
    skos:definition "Relates an ontology to one of its ontology modules."@en ;
    rdfs:domain nexus:Ontology ;
    rdfs:range nexus:OntologyModule .

nexus:isOntologyModuleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf nexus:hasOntologyModule ;
    rdfs:label "is ontology module of"@en ;
    skos:definition "Relates an ontology module to the ontology on which it depends."@en ;
    rdfs:domain nexus:OntologyModule ;
    rdfs:range nexus:Ontology .

# HOW WE KNOW — ontology carries class
nexus:hasOntologyClass a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has ontology class"@en ;
    skos:definition "Relates an ontology to a class defined within it."@en ;
    rdfs:domain nexus:Ontology ;
    rdfs:range nexus:OntologyClass .

# HOW WE KNOW — ontology carries object property
nexus:hasOntologyObjectProperty a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has ontology object property"@en ;
    skos:definition "Relates an ontology to an object property defined within it."@en ;
    rdfs:domain nexus:Ontology ;
    rdfs:range nexus:OntologyObjectProperty .

# HOW WE KNOW — knowledge graph carries graph view
nexus:hasGraphView a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has graph view"@en ;
    skos:definition "Relates a knowledge graph to a graph view derived from it."@en ;
    rdfs:domain nexus:KnowledgeGraph ;
    rdfs:range nexus:GraphView .

# HOW WE KNOW — graph view carries graph filter
nexus:hasGraphFilter a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has graph filter"@en ;
    skos:definition "Relates a graph view to a graph filter used in it."@en ;
    rdfs:domain nexus:GraphView ;
    rdfs:range nexus:GraphFilter .

nexus:includesKnowledgeGraph a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    rdfs:label "includes knowledge graph"@en ;
    skos:definition "Relates a graph view to a knowledge graph it includes."@en ;
    rdfs:domain nexus:GraphView ;
    rdfs:range nexus:KnowledgeGraph .

# HOW WE KNOW — file system carries files
nexus:hasFiles a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has files"@en ;
    skos:definition "Relates a file system to files accessible through it."@en ;
    rdfs:domain nexus:FileSystem ;
    rdfs:range nexus:Files .

# HOW WE KNOW — workspace carries marketplace apps
nexus:hasMarketplaceApps a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    rdfs:label "has marketplace apps"@en ;
    skos:definition "Relates a workspace to a marketplace application available in or associated with it."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:MarketplaceApps .

# HOW WE KNOW → WHO — AI model depends on provider organization
nexus:hasProvider a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    rdfs:label "has provider"@en ;
    skos:definition "Relates an AI model to the organization that provides it."@en ;
    rdfs:domain nexus:AIModel ;
    rdfs:range abi:Organization .

# WHY — concretization pairs for workspace role
nexus:hasWorkspaceRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isWorkspaceRoleOf ;
    rdfs:label "has workspace role"@en ;
    skos:definition "Relates a workspace to a workspace role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Workspace ;
    rdfs:range nexus:WorkspaceRole .

nexus:isWorkspaceRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasWorkspaceRole ;
    rdfs:label "is workspace role of"@en ;
    skos:definition "Relates a workspace role to the workspace of which it is the role-side concretization."@en ;
    rdfs:domain nexus:WorkspaceRole ;
    rdfs:range nexus:Workspace .

# WHY — concretization pairs for search role
nexus:hasSearchRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isSearchRoleOf ;
    rdfs:label "has search role"@en ;
    skos:definition "Relates a search artifact to a search role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Search ;
    rdfs:range nexus:SearchRole .

nexus:isSearchRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasSearchRole ;
    rdfs:label "is search role of"@en ;
    skos:definition "Relates a search role to the search artifact of which it is the role-side concretization."@en ;
    rdfs:domain nexus:SearchRole ;
    rdfs:range nexus:Search .

