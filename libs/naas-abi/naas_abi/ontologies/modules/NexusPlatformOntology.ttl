    skos:definition "Relates a graph view role to the graph view of which it is the role-side concretization."@en ;
    rdfs:domain nexus:GraphViewRole ;
    rdfs:range nexus:GraphView .

nexus:hasGraphFilterRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isGraphFilterRoleOf ;
    rdfs:label "has graph filter role"@en ;
    skos:definition "Relates a graph filter to a graph filter role that concretizes it in platform use."@en ;
    rdfs:domain nexus:GraphFilter ;
    rdfs:range nexus:GraphFilterRole .

nexus:isGraphFilterRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasGraphFilterRole ;
    rdfs:label "is graph filter role of"@en ;
    skos:definition "Relates a graph filter role to the graph filter of which it is the role-side concretization."@en ;
    rdfs:domain nexus:GraphFilterRole ;
    rdfs:range nexus:GraphFilter .

nexus:hasFileRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isFileRoleOf ;
    rdfs:label "has file role"@en ;
    skos:definition "Relates a file artifact to a file role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Files ;
    rdfs:range nexus:FileRole .

nexus:isFileRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
