    owl:inverseOf nexus:isOntologyObjectPropertyRoleOf ;
    rdfs:label "has ontology object property role"@en ;
    skos:definition "Relates an ontology object property to an ontology object property role that concretizes it in platform use."@en ;
    rdfs:domain nexus:OntologyObjectProperty ;
    rdfs:range nexus:OntologyObjectPropertyRole .

nexus:isOntologyObjectPropertyRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasOntologyObjectPropertyRole ;
    rdfs:label "is ontology object property role of"@en ;
    skos:definition "Relates an ontology object property role to the ontology object property of which it is the role-side concretization."@en ;
    rdfs:domain nexus:OntologyObjectPropertyRole ;
    rdfs:range nexus:OntologyObjectProperty .

nexus:hasKnowledgeGraphRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isKnowledgeGraphRoleOf ;
    rdfs:label "has knowledge graph role"@en ;
    skos:definition "Relates a knowledge graph to a knowledge graph role that concretizes it in platform use."@en ;
    rdfs:domain nexus:KnowledgeGraph ;
    rdfs:range nexus:KnowledgeGraphRole .

nexus:isKnowledgeGraphRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasKnowledgeGraphRole ;
    rdfs:label "is knowledge graph role of"@en ;
    skos:definition "Relates a knowledge graph role to the knowledge graph of which it is the role-side concretization."@en ;
    rdfs:domain nexus:KnowledgeGraphRole ;
    rdfs:range nexus:KnowledgeGraph .

nexus:hasGraphViewRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isGraphViewRoleOf ;
    rdfs:label "has graph view role"@en ;
    skos:definition "Relates a graph view to a graph view role that concretizes it in platform use."@en ;
    rdfs:domain nexus:GraphView ;
