# WHY — concretization pairs for marketplace app role
nexus:hasMarketplaceAppRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isMarketplaceAppRoleOf ;
    rdfs:label "has marketplace app role"@en ;
    skos:definition "Relates a marketplace application to a marketplace application role that concretizes it in platform use."@en ;
    rdfs:domain nexus:MarketplaceApps ;
    rdfs:range nexus:MarketplaceAppRole .

nexus:isMarketplaceAppRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasMarketplaceAppRole ;
    rdfs:label "is marketplace app role of"@en ;
    skos:definition "Relates a marketplace application role to the marketplace application of which it is the role-side concretization."@en ;
    rdfs:domain nexus:MarketplaceAppRole ;
