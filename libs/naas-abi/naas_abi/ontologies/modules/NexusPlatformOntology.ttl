nexus:hasConversationRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isConversationRoleOf ;
    rdfs:label "has conversation role"@en ;
    skos:definition "Relates a conversation to a conversation role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Conversation ;
    rdfs:range nexus:ConversationRole .

nexus:isConversationRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasConversationRole ;
    rdfs:label "is conversation role of"@en ;
    skos:definition "Relates a conversation role to the conversation of which it is the role-side concretization."@en ;
    rdfs:domain nexus:ConversationRole ;
    rdfs:range nexus:Conversation .

# WHY — concretization pairs for message role
nexus:hasMessageRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isMessageRoleOf ;
    rdfs:label "has message role"@en ;
    skos:definition "Relates a message to a message role that concretizes it in platform use."@en ;
