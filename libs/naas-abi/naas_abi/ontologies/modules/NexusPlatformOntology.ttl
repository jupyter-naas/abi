nexus:isMessageRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasMessageRole ;
    rdfs:label "is message role of"@en ;
    skos:definition "Relates a message role to the message of which it is the role-side concretization."@en ;
    rdfs:domain nexus:MessageRole ;
    rdfs:range nexus:Message .

# WHY — concretization pairs for agent role
nexus:hasAgentRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isAgentRoleOf ;
    rdfs:label "has agent role"@en ;
    skos:definition "Relates an agent to an agent role that concretizes it in platform use."@en ;
    rdfs:domain nexus:Agent ;
    rdfs:range nexus:AgentRole .

nexus:isAgentRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasAgentRole ;
    rdfs:label "is agent role of"@en ;
    skos:definition "Relates an agent role to the agent of which it is the role-side concretization."@en ;
    rdfs:domain nexus:AgentRole ;
    rdfs:range nexus:Agent .

# WHY — concretization pairs for ontology role
nexus:hasOntologyRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isOntologyRoleOf ;
    rdfs:label "has ontology role"@en ;
    skos:definition "Relates an ontology to an ontology role that concretizes it in platform use."@en ;
