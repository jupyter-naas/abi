nexus:hasOntologyModuleRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isOntologyModuleRoleOf ;
    rdfs:label "has ontology module role"@en ;
    skos:definition "Relates an ontology module to an ontology module role that concretizes it in platform use."@en ;
    rdfs:domain nexus:OntologyModule ;
