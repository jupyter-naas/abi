    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasOntologyClassRole ;
    rdfs:label "is ontology class role of"@en ;
    skos:definition "Relates an ontology class role to the ontology class of which it is the role-side concretization."@en ;
    rdfs:domain nexus:OntologyClassRole ;
    rdfs:range nexus:OntologyClass .

