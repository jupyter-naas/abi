    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf nexus:hasOntologyModuleRole ;
    rdfs:label "is ontology module role of"@en ;
    skos:definition "Relates an ontology module role to the ontology module of which it is the role-side concretization."@en ;
    rdfs:domain nexus:OntologyModuleRole ;
    rdfs:range nexus:OntologyModule .

