nexus:hasGraphFilterRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf nexus:isGraphFilterRoleOf ;
    rdfs:label "has graph filter role"@en ;
    skos:definition "Relates a graph filter to a graph filter role that concretizes it in platform use."@en ;
    rdfs:domain nexus:GraphFilter ;
