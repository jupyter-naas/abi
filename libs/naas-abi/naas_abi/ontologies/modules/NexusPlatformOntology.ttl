nexus:hasFileSystemRole a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000058 ;
    owl:inverseOf nexus:isFileSystemRoleOf ;
    rdfs:label "has file system role"@en ;
    skos:definition "Relates a file system to a file system role that concretizes it in platform use."@en ;
    rdfs:domain nexus:FileSystem ;
    rdfs:range nexus:FileSystemRole .

nexus:isFileSystemRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000059 ;
    owl:inverseOf nexus:hasFileSystemRole ;
    rdfs:label "is file system role of"@en ;
    skos:definition "Relates a file system role to the file system of which it is the role-side concretization."@en ;
    rdfs:domain nexus:FileSystemRole ;
