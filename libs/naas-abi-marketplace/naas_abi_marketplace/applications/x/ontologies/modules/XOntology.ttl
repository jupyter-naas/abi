@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dc:    <http://purl.org/dc/terms/> .
@prefix dc11:  <http://purl.org/dc/elements/1.1/> .
@prefix bfo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix abi:   <http://ontology.naas.ai/abi/> .
@prefix x:     <http://ontology.naas.ai/x/> .

x:XOntology a owl:Ontology ;
  owl:imports <http://ontology.naas.ai/abi/Ontology> ;
  dc:title "X (Twitter) Ontology"@en ;
  dc:description "Ontology for the X (Twitter) domain. Models tweets, X user accounts, public engagement metrics, and the SearchRecentTweets process exposed by the X v2 GET /2/tweets/search/recent endpoint."@en ;
  dc:license <https://creativecommons.org/licenses/by/4.0/> ;
  rdfs:comment "Ontology for the X (Twitter) domain."@en ;
  dc11:contributor "Florent Ravenel" ;
  dc11:date "2026-06-02"^^xsd:date .

#################################################################
#    Object Properties
#################################################################

# WHO ↔ HOW WE KNOW — person carries an X user account
x:hasXUserAccount a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isXUserAccountOf ;
    rdfs:label "has X user account"@en ;
    skos:definition "Relates a person to the X user account that generically depends on them within the X platform."@en ;
    rdfs:domain abi:Person ;
    rdfs:range x:XUser .

x:isXUserAccountOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasXUserAccount ;
    rdfs:label "is X user account of"@en ;
    skos:definition "Relates an X user account to the person on which it generically depends."@en ;
    rdfs:domain x:XUser ;
    rdfs:range abi:Person .

# HOW WE KNOW — X user account carries authored tweets
x:hasAuthoredTweet a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isAuthoredBy ;
    rdfs:label "has authored tweet"@en ;
    skos:definition "Relates an X user account to a tweet authored by it on the X platform."@en ;
    rdfs:domain x:XUser ;
    rdfs:range x:Tweet .

x:isAuthoredBy a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasAuthoredTweet ;
    rdfs:label "is authored by"@en ;
    skos:definition "Relates a tweet to the X user account that authored it."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:XUser .

# HOW WE KNOW — tweet carries public engagement metrics
x:hasPublicMetrics a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isPublicMetricsOf ;
    rdfs:label "has public metrics"@en ;
    skos:definition "Relates a tweet to the public engagement metrics artifact exposed by the X v2 API."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:TweetPublicMetrics .

x:isPublicMetricsOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasPublicMetrics ;
    rdfs:label "is public metrics of"@en ;
    skos:definition "Relates a public engagement metrics artifact to the tweet on which it depends."@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range x:Tweet .

# WHAT ↔ HOW WE KNOW — search process uses a search query
x:usesSearchQuery a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:concretizes ;
    owl:inverseOf x:isSearchQueryOf ;
    rdfs:label "uses search query"@en ;
    skos:definition "Relates a recent-tweet search process to the search query artifact it executes against the X v2 API."@en ;
    rdfs:domain x:SearchRecentTweets ;
    rdfs:range x:SearchQuery .

x:isSearchQueryOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isConcretizedBy ;
    owl:inverseOf x:usesSearchQuery ;
    rdfs:label "is search query of"@en ;
    skos:definition "Relates a search query artifact to the recent-tweet search process that executes it."@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range x:SearchRecentTweets .

# WHAT ↔ HOW WE KNOW — process produces a result set
x:producesSearchResult a owl:ObjectProperty ;
    owl:inverseOf x:isProducedBy ;
    rdfs:label "produces search result"@en ;
    skos:definition "Relates a tweet-ingestion process to the search result set it produces."@en ;
    rdfs:domain abi:Process ;
    rdfs:range x:SearchResultSet .

x:isProducedBy a owl:ObjectProperty ;
    owl:inverseOf x:producesSearchResult ;
    rdfs:label "is produced by"@en ;
    skos:definition "Relates a search result set to the process that produced it."@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range abi:Process .

# WHAT — file-import process is temporally preceded by a search process
x:isPrecededBy a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000062 ;
    owl:inverseOf x:precedes ;
    rdfs:label "is preceded by"@en ;
    skos:definition "Relates a process to another process that precedes it temporally; sub-property of BFO preceded_by (BFO_0000062)."@en ;
    rdfs:domain abi:Process ;
    rdfs:range abi:Process .

x:precedes a owl:ObjectProperty ;
    rdfs:subPropertyOf bfo:BFO_0000063 ;
    owl:inverseOf x:isPrecededBy ;
    rdfs:label "precedes"@en ;
    skos:definition "Relates a process to another process that follows it temporally; sub-property of BFO precedes (BFO_0000063)."@en ;
    rdfs:domain abi:Process ;
    rdfs:range abi:Process .

# WHAT ↔ HOW WE KNOW — file-import process reads a tweet dump file
x:imports_file a owl:ObjectProperty ;
    rdfs:label "imports file"@en ;
    skos:definition "Relates a tweet-file import process to the tweet dataset file it reads from object storage."@en ;
    rdfs:domain x:TweetFileImport ;
    rdfs:range x:TweetFile .

# HOW WE KNOW — search result set contains tweets
x:containsTweet a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isContainedInSearchResultSet ;
    rdfs:label "contains tweet"@en ;
    skos:definition "Relates a search result set to a tweet it contains."@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range x:Tweet .

x:isContainedInSearchResultSet a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:containsTweet ;
    rdfs:label "is contained in search result set"@en ;
    skos:definition "Relates a tweet to a search result set in which it appears."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:SearchResultSet .

# WHAT ↔ HOW WE KNOW — search process retrieves the tweets it matched
x:retrievesTweet a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasParticipant ;
    rdfs:label "retrieves tweet"@en ;
    skos:definition "Relates a recent-tweet search process to a tweet it retrieved from the X v2 search response (the matched `data` tweets)."@en ;
    rdfs:domain x:SearchRecentTweets ;
    rdfs:range x:Tweet .

# WHAT ↔ HOW WE KNOW — search process retrieves the expanded user accounts
x:retrievesUser a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasParticipant ;
    rdfs:label "retrieves user"@en ;
    skos:definition "Relates a recent-tweet search process to an X user account expanded in its response (the `includes.users` of the X v2 search response)."@en ;
    rdfs:domain x:SearchRecentTweets ;
    rdfs:range x:XUser .

# WHAT ↔ HOW WE KNOW — search process retrieves the expanded media artifacts
x:retrievesMedia a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasParticipant ;
    rdfs:label "retrieves media"@en ;
    skos:definition "Relates a recent-tweet search process to a media artifact expanded in its response (the `includes.media` of the X v2 search response)."@en ;
    rdfs:domain x:SearchRecentTweets ;
    rdfs:range x:Media .

# WHO — search process initiated by an X user account
x:executedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasParticipant ;
    rdfs:label "executed by"@en ;
    skos:definition "Relates a recent-tweet search process to the X user account on whose behalf the API call was made."@en ;
    rdfs:domain x:SearchRecentTweets ;
    rdfs:range x:XUser .

# WHEN — search process occupies a temporal interval
x:hasSearchInterval a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:occupiesTemporalRegion ;
    rdfs:label "has search interval"@en ;
    skos:definition "Relates an X process to the temporal interval that bounds its execution, carrying a first instant (searchStartedAt) and a last instant (searchEndedAt)."@en ;
    rdfs:domain abi:Process ;
    rdfs:range x:SearchInterval .

# WHEN — search executed at a temporal instant
x:executedAt a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:occupiesTemporalRegion ;
    rdfs:label "executed at"@en ;
    skos:definition "Relates a recent-tweet search process to the temporal instant at which the API call was issued."@en ;
    rdfs:domain x:SearchRecentTweets ;
    rdfs:range abi:TemporalInstant .

# WHEN — tweet was posted at a temporal instant
x:tweetedAt a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:occupiesTemporalRegion ;
    rdfs:label "tweeted at"@en ;
    skos:definition "Relates a tweet to the temporal instant at which it was published on the X platform."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range abi:TemporalInstant .

# WHEN — search interval bounds
x:searchStartedAt a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasFirstInstant ;
    rdfs:label "search started at"@en ;
    skos:definition "Relates a search interval to the temporal instant at which the search process started."@en ;
    rdfs:domain x:SearchInterval ;
    rdfs:range abi:TemporalInstant .

x:searchEndedAt a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:hasLastInstant ;
    rdfs:label "search ended at"@en ;
    skos:definition "Relates a search interval to the temporal instant at which the search process completed."@en ;
    rdfs:domain x:SearchInterval ;
    rdfs:range abi:TemporalInstant .

# WHY — concretization pair for search query role
x:hasSearchQueryRole a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    owl:inverseOf x:isSearchQueryRoleOf ;
    rdfs:label "has search query role"@en ;
    skos:definition "Relates a search query artifact to a search query role that concretizes it during search execution."@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range x:SearchQueryRole .

x:isSearchQueryRoleOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:inheresIn ;
    owl:inverseOf x:hasSearchQueryRole ;
    rdfs:label "is search query role of"@en ;
    skos:definition "Relates a search query role to the search query artifact in which it inheres."@en ;
    rdfs:domain x:SearchQueryRole ;
    rdfs:range x:SearchQuery .

# HOW IT IS — tweet bears a language quality
x:hasLanguage a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:bearerOf ;
    rdfs:label "has language"@en ;
    skos:definition "Relates a tweet to the natural-language quality detected for its text content."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:TweetLanguage .

# HOW WE KNOW — X user account carries its public metrics
x:hasUserPublicMetrics a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isUserPublicMetricsOf ;
    rdfs:label "has user public metrics"@en ;
    skos:definition "Relates an X user account to the public account metrics artifact (followers, following, tweet, listed, like and media counts) exposed by the X v2 API."@en ;
    rdfs:domain x:XUser ;
    rdfs:range x:XUserPublicMetrics .

x:isUserPublicMetricsOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasUserPublicMetrics ;
    rdfs:label "is user public metrics of"@en ;
    skos:definition "Relates a public account metrics artifact to the X user account on which it depends."@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range x:XUser .

# HOW WE KNOW — tweet carries attached media
x:hasAttachedMedia a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isAttachedMediaOf ;
    rdfs:label "has attached media"@en ;
    skos:definition "Relates a tweet to a media artifact (photo, video, animated gif) attached to it, resolved through the X v2 `attachments.media_keys` expansion."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:Media .

x:isAttachedMediaOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasAttachedMedia ;
    rdfs:label "is attached media of"@en ;
    skos:definition "Relates a media artifact to a tweet to which it is attached."@en ;
    rdfs:domain x:Media ;
    rdfs:range x:Tweet .

# HOW WE KNOW — tweet carries context annotations
x:hasContextAnnotation a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isContextAnnotationOf ;
    rdfs:label "has context annotation"@en ;
    skos:definition "Relates a tweet to a context annotation (domain/entity classification pair) inferred for it by the X platform, as exposed by the X v2 `context_annotations` field."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:ContextAnnotation .

x:isContextAnnotationOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasContextAnnotation ;
    rdfs:label "is context annotation of"@en ;
    skos:definition "Relates a context annotation to a tweet it classifies."@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range x:Tweet .

# HOW WE KNOW — tweet carries URL entities
x:hasUrlEntity a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:isCarrierOf ;
    owl:inverseOf x:isUrlEntityOf ;
    rdfs:label "has url entity"@en ;
    skos:definition "Relates a tweet to a URL entity contained in its text, as exposed by the X v2 `entities.urls` field."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:TweetUrl .

x:isUrlEntityOf a owl:ObjectProperty ;
    rdfs:subPropertyOf abi:genericallyDependsOn ;
    owl:inverseOf x:hasUrlEntity ;
    rdfs:label "is url entity of"@en ;
    skos:definition "Relates a URL entity to a tweet whose text contains it."@en ;
    rdfs:domain x:TweetUrl ;
    rdfs:range x:Tweet .

# HOW WE KNOW — tweet mentions X user accounts
x:mentionsUser a owl:ObjectProperty ;
    rdfs:label "mentions user"@en ;
    skos:definition "Relates a tweet to an X user account mentioned in its text, as exposed by the X v2 `entities.mentions` field."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:XUser .

# HOW WE KNOW — tweet was posted in reply to an X user account
x:inReplyToUser a owl:ObjectProperty ;
    rdfs:label "in reply to user"@en ;
    skos:definition "Relates a reply tweet to the X user account whose tweet it replies to, as exposed by the X v2 `in_reply_to_user_id` field."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:XUser .

# HOW WE KNOW — tweet references other tweets
x:referencesTweet a owl:ObjectProperty ;
    rdfs:label "references tweet"@en ;
    skos:definition "Relates a tweet to another tweet it references (reply, quote or retweet), as exposed by the X v2 `referenced_tweets` field."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:Tweet .

x:repliesToTweet a owl:ObjectProperty ;
    rdfs:subPropertyOf x:referencesTweet ;
    rdfs:label "replies to tweet"@en ;
    skos:definition "Relates a reply tweet to the tweet it replies to (`referenced_tweets[].type == 'replied_to'`)."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:Tweet .

x:quotesTweet a owl:ObjectProperty ;
    rdfs:subPropertyOf x:referencesTweet ;
    rdfs:label "quotes tweet"@en ;
    skos:definition "Relates a quote tweet to the tweet it quotes (`referenced_tweets[].type == 'quoted'`)."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:Tweet .

x:retweetsTweet a owl:ObjectProperty ;
    rdfs:subPropertyOf x:referencesTweet ;
    rdfs:label "retweets tweet"@en ;
    skos:definition "Relates a retweet to the tweet it retweets (`referenced_tweets[].type == 'retweeted'`)."@en ;
    rdfs:domain x:Tweet ;
    rdfs:range x:Tweet .

#################################################################
#    Classes
#################################################################

# --- Continuants ---

# Site (WHERE)
x:XPlatform a owl:Class ;
    rdfs:label "X Platform"@en ;
    skos:altLabel "Twitter Platform"@en ;
    skos:definition "A site representing the X (Twitter) social media platform in which user accounts participate, tweets are published, and search processes are executed against the X v2 API."@en ;
    skos:example "x.com", "api.x.com"@en ;
    rdfs:subClassOf abi:Site .

# Generically dependent continuant (HOW WE KNOW)

# HOW WE KNOW — X user account (GDC depending on a person)
x:XUser a owl:Class ;
    rdfs:label "X User"@en ;
    skos:altLabel "X Account"@en , "Twitter User"@en ;
    skos:definition "A generically dependent continuant representing a user account on the X (Twitter) platform, carrying the identity of a person within X and identified by a numeric author id."@en ;
    skos:example "Account with id 1752407607820607488", "@TwitterDev"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isXUserAccountOf ;
          owl:allValuesFrom abi:Person
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasUserPublicMetrics ;
          owl:allValuesFrom x:XUserPublicMetrics
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:author_id ;
          owl:someValuesFrom xsd:string
        ] .

# HOW WE KNOW — tweet (GDC)
x:Tweet a owl:Class ;
    rdfs:label "Tweet"@en ;
    skos:altLabel "Post"@en , "X Post"@en ;
    skos:definition "A generically dependent continuant representing an individual post published on the X (Twitter) platform, identified by a numeric tweet id and bearing text content, language, creation timestamp, and public engagement metrics as exposed by the X v2 API."@en ;
    skos:example "Tweet 2061859064825446876 by author 1752407607820607488 about Roland Garros"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isAuthoredBy ;
          owl:someValuesFrom x:XUser
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isAuthoredBy ;
          owl:allValuesFrom x:XUser
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasPublicMetrics ;
          owl:allValuesFrom x:TweetPublicMetrics
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasLanguage ;
          owl:allValuesFrom x:TweetLanguage
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasAttachedMedia ;
          owl:allValuesFrom x:Media
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasContextAnnotation ;
          owl:allValuesFrom x:ContextAnnotation
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasUrlEntity ;
          owl:allValuesFrom x:TweetUrl
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:mentionsUser ;
          owl:allValuesFrom x:XUser
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:inReplyToUser ;
          owl:allValuesFrom x:XUser
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:referencesTweet ;
          owl:allValuesFrom x:Tweet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:tweetedAt ;
          owl:someValuesFrom abi:TemporalInstant
        ] .

# HOW WE KNOW — tweet public metrics (GDC)
x:TweetPublicMetrics a owl:Class ;
    rdfs:label "Tweet Public Metrics"@en ;
    skos:definition "A generically dependent continuant representing the public engagement metrics of a tweet (retweet, reply, like, quote, bookmark and impression counts) as exposed by the X v2 API at a point in time."@en ;
    skos:example "retweet_count: 0, reply_count: 0, like_count: 1, quote_count: 0, bookmark_count: 0, impression_count: 37"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isPublicMetricsOf ;
          owl:someValuesFrom x:Tweet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isPublicMetricsOf ;
          owl:allValuesFrom x:Tweet
        ] .

# HOW WE KNOW — X user account public metrics (GDC)
x:XUserPublicMetrics a owl:Class ;
    rdfs:label "X User Public Metrics"@en ;
    skos:definition "A generically dependent continuant representing the public account metrics of an X user (followers, following, tweet, listed, like and media counts) as exposed by the X v2 API at a point in time."@en ;
    skos:example "followers_count: 7309, following_count: 2591, tweet_count: 7080, listed_count: 89, like_count: 810, media_count: 1915"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isUserPublicMetricsOf ;
          owl:someValuesFrom x:XUser
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isUserPublicMetricsOf ;
          owl:allValuesFrom x:XUser
        ] .

# HOW WE KNOW — media artifact attached to a tweet (GDC)
x:Media a owl:Class ;
    rdfs:label "Media"@en ;
    skos:altLabel "Tweet Media"@en ;
    skos:definition "A generically dependent continuant representing a media artifact (photo, video or animated gif) attached to a tweet, identified by a media key and resolved through the X v2 `attachments.media_keys` expansion."@en ;
    skos:example "media_key 13_2063731151118766080, a 1920x1080 video of 69149 ms"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isAttachedMediaOf ;
          owl:someValuesFrom x:Tweet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isAttachedMediaOf ;
          owl:allValuesFrom x:Tweet
        ] .

# HOW WE KNOW — context annotation classifying a tweet (GDC)
x:ContextAnnotation a owl:Class ;
    rdfs:label "Context Annotation"@en ;
    skos:definition "A generically dependent continuant representing a domain/entity classification pair inferred for a tweet by the X platform, as exposed by the X v2 `context_annotations` field."@en ;
    skos:example "domain 'Political Body' (88) / entity 'North Atlantic Treaty Organization' (1016738021939351558)"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isContextAnnotationOf ;
          owl:someValuesFrom x:Tweet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isContextAnnotationOf ;
          owl:allValuesFrom x:Tweet
        ] .

# HOW WE KNOW — URL entity contained in a tweet (GDC)
x:TweetUrl a owl:Class ;
    rdfs:label "Tweet URL"@en ;
    skos:altLabel "URL Entity"@en ;
    skos:definition "A generically dependent continuant representing a URL contained in the text of a tweet, with its expanded and display forms and any unrolled page title/description, as exposed by the X v2 `entities.urls` field."@en ;
    skos:example "https://t.co/EzUWbYROqa expanding to https://turdef.com/article/efes-2026-turkiye-to-nato-or-nato-to-turkiye"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isUrlEntityOf ;
          owl:someValuesFrom x:Tweet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isUrlEntityOf ;
          owl:allValuesFrom x:Tweet
        ] .

# HOW WE KNOW — search query artifact (GDC)
x:SearchQuery a owl:Class ;
    rdfs:label "Search Query"@en ;
    skos:altLabel "Recent Tweet Search Query"@en ;
    skos:definition "A generically dependent continuant representing an X v2 recent-tweet search query expression and its parameters, used as input to a SearchRecentTweets process."@en ;
    skos:example "query='(from:TwitterDev OR from:TwitterAPI) has:media -is:retweet', max_results=100, sort_order='recency'"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:hasSearchQueryRole ;
          owl:someValuesFrom x:SearchQueryRole
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasSearchQueryRole ;
          owl:allValuesFrom x:SearchQueryRole
        ] .

# HOW WE KNOW — search result set (GDC)
x:SearchResultSet a owl:Class ;
    rdfs:label "Search Result Set"@en ;
    skos:altLabel "Tweet Search Result"@en ;
    skos:definition "A generically dependent continuant representing the collection of tweets returned by a SearchRecentTweets process for a given query and parameter set, persisted as a JSON document in the local datastore."@en ;
    skos:example "Result set 21dcaa8c.json containing 100 tweets returned for query 'Roland Garros lang:en' on 2026-06-02"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant ,
        [ a owl:Restriction ;
          owl:onProperty x:isProducedBy ;
          owl:someValuesFrom x:SearchRecentTweets
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:containsTweet ;
          owl:allValuesFrom x:Tweet
        ] .

# Generically dependent continuant — tweet dataset file in object storage
x:TweetFile a owl:Class ;
    rdfs:label "Tweet File"@en ;
    skos:altLabel "Tweet Dataset File"@en ;
    skos:definition "A generically dependent continuant representing a tweet dataset file (JSON / NDJSON dump) stored in object storage and ingested into the X graph by a TweetFileImport process."@en ;
    skos:example "archive-2026-06-03.ndjson with sha256 a3f2… stored under prefix x/uploads"@en ;
    rdfs:subClassOf abi:GenericallyDependentContinuant .

x:sha256 a owl:DatatypeProperty ;
    rdfs:label "sha256"@en ;
    rdfs:domain x:TweetFile ;
    rdfs:range xsd:string ;
    skos:definition "SHA-256 hex digest of the tweet dataset file bytes; used for deduplication before ingestion."@en ;
    skos:example "a3f2c1d4e5f6..." .

x:object_storage_prefix a owl:DatatypeProperty ;
    rdfs:label "object storage prefix"@en ;
    rdfs:domain x:TweetFile ;
    rdfs:range xsd:string ;
    skos:definition "Object-storage prefix under which the tweet dataset file is stored."@en ;
    skos:example "x/uploads" .

x:object_storage_key a owl:DatatypeProperty ;
    rdfs:label "object storage key"@en ;
    rdfs:domain x:TweetFile ;
    rdfs:range xsd:string ;
    skos:definition "Object key of the tweet dataset file under its storage prefix."@en ;
    skos:example "archive-2026-06-03.ndjson" .

x:file_size_bytes a owl:DatatypeProperty ;
    rdfs:label "file size bytes"@en ;
    rdfs:domain x:TweetFile ;
    rdfs:range xsd:integer ;
    skos:definition "Size of the tweet dataset file in bytes."@en ;
    skos:example "1048576" .

# Quality (HOW IT IS) — tweet language
x:TweetLanguage a owl:Class ;
    rdfs:label "Tweet Language"@en ;
    skos:definition "A quality of a tweet representing the natural language detected for its text content, expressed as an IETF BCP 47 language tag."@en ;
    skos:example "en", "fr", "es"@en ;
    rdfs:subClassOf abi:Quality ,
        [ a owl:Restriction ;
          owl:onProperty abi:inheresIn ;
          owl:someValuesFrom x:Tweet
        ] .

# Role (WHY) — search query role
x:SearchQueryRole a owl:Class ;
    rdfs:label "Search Query Role"@en ;
    skos:definition "A role borne by a search query artifact in relation to a recent-tweet search process during which it is used as the query input."@en ;
    rdfs:subClassOf abi:Role ,
        [ a owl:Restriction ;
          owl:onProperty x:isSearchQueryRoleOf ;
          owl:someValuesFrom x:SearchQuery
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isSearchQueryRoleOf ;
          owl:allValuesFrom x:SearchQuery
        ] .

# --- Occurrents ---

# Process (WHAT) — tweet file import
x:TweetFileImport a owl:Class ;
    rdfs:label "Tweet File Import"@en ;
    skos:definition "A process by which a tweet dataset file in object storage is streamed into the X graph. It is preceded by a SearchRecentTweets process that produced the file and, upon completion, precedes a new SearchRecentTweets run to build content instances from the ingested tweets."@en ;
    skos:example "Import of archive-2026-06-03.ndjson (sha256 a3f2…) yielding 1.2M tweets on 2026-06-09, followed by a SearchRecentTweets pipeline pass over the ingested dataset."@en ;
    rdfs:subClassOf abi:Process ,
        [ a owl:Restriction ;
          owl:onProperty x:imports_file ;
          owl:someValuesFrom x:TweetFile
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:imports_file ;
          owl:allValuesFrom x:TweetFile
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:isPrecededBy ;
          owl:someValuesFrom x:SearchRecentTweets
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasSearchInterval ;
          owl:someValuesFrom x:SearchInterval
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasSearchInterval ;
          owl:allValuesFrom x:SearchInterval
        ] .

# Process (WHAT) — central focus
x:SearchRecentTweets a owl:Class ;
    rdfs:label "Search Recent Tweets"@en ;
    skos:altLabel "Recent Tweet Search"@en ;
    skos:definition "A process by which the X v2 GET /2/tweets/search/recent endpoint is queried to retrieve tweets posted in the last seven days that match a given query and parameter set; the process consumes a SearchQuery and produces a SearchResultSet containing the matched Tweet artifacts."@en ;
    skos:example "A search for query 'Roland Garros lang:en' executed on 2026-06-02 producing result set 21dcaa8c containing 100 tweets."@en ;
    rdfs:subClassOf abi:Process ,
        [ a owl:Restriction ;
          owl:onProperty x:usesSearchQuery ;
          owl:someValuesFrom x:SearchQuery
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:usesSearchQuery ;
          owl:allValuesFrom x:SearchQuery
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:producesSearchResult ;
          owl:someValuesFrom x:SearchResultSet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:producesSearchResult ;
          owl:allValuesFrom x:SearchResultSet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasSearchInterval ;
          owl:someValuesFrom x:SearchInterval
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:hasSearchInterval ;
          owl:allValuesFrom x:SearchInterval
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:retrievesTweet ;
          owl:allValuesFrom x:Tweet
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:retrievesUser ;
          owl:allValuesFrom x:XUser
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:retrievesMedia ;
          owl:allValuesFrom x:Media
        ] ,
        [ a owl:Restriction ;
          owl:onProperty abi:occursIn ;
          owl:allValuesFrom x:XPlatform
        ] .

# Temporal region (WHEN) — bounded interval of a search process
x:SearchInterval a owl:Class ;
    rdfs:label "Search Interval"@en ;
    skos:definition "A one-dimensional temporal region that bounds a SearchRecentTweets process, from the start of the API call sequence to its completion."@en ;
    skos:example "Search interval from 2026-06-02T19:15:00Z to 2026-06-02T19:15:50Z"@en ;
    rdfs:subClassOf abi:TemporalRegion ,
        [ a owl:Restriction ;
          owl:onProperty x:searchStartedAt ;
          owl:someValuesFrom abi:TemporalInstant
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:searchStartedAt ;
          owl:allValuesFrom abi:TemporalInstant
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:searchEndedAt ;
          owl:someValuesFrom abi:TemporalInstant
        ] ,
        [ a owl:Restriction ;
          owl:onProperty x:searchEndedAt ;
          owl:allValuesFrom abi:TemporalInstant
        ] .

#################################################################
#    Data Properties
#################################################################

# Tweet identification and content
x:tweet_id a owl:DatatypeProperty ;
    rdfs:label "tweet id"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "The unique numeric identifier of a tweet on the X platform; corresponds to the `id` field returned by the X v2 API."@en ;
    skos:example "2061859064825446876" .

x:tweet_text a owl:DatatypeProperty ;
    rdfs:label "tweet text"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "The text content of a tweet as published on the X platform; corresponds to the `text` field returned by the X v2 API."@en ;
    skos:example "The legendary @gugakuerten set the stage, now Fonseca is absolutely electrifying the 2026 Roland Garros!" .

x:full_text a owl:DatatypeProperty ;
    rdfs:label "full text"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "The complete, untruncated text content of a tweet on the X platform. When a tweet exceeds the standard length, the X v2 API truncates the `text` field and exposes the full content in the `note_tweet.text` field; this property carries `note_tweet.text` when present and otherwise falls back to `text`."@en ;
    skos:example "Les États-Unis ont renoncé à d'importants engagements militaires envers l'Otan. Le Pentagone a retiré du commandement de l'Alliance son groupe aéronaval, son groupe de bombardiers et plus de 50 chasseurs." .

x:tweet_created_at a owl:DatatypeProperty ;
    rdfs:label "tweet created at"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:dateTime ;
    skos:definition "The UTC timestamp at which the tweet was published on the X platform; corresponds to the `created_at` field returned by the X v2 API."@en ;
    skos:example "2026-06-02T17:14:43.000Z" .

x:edit_history_tweet_id a owl:DatatypeProperty ;
    rdfs:label "edit history tweet id"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "An identifier in the chronological edit history of a tweet, including the original tweet id and any subsequent edited versions; corresponds to the `edit_history_tweet_ids` field returned by the X v2 API."@en ;
    skos:example "2061859064825446876" .

# Tweet language
x:lang a owl:DatatypeProperty ;
    rdfs:label "language code"@en ;
    rdfs:domain x:TweetLanguage ;
    rdfs:range xsd:string ;
    skos:definition "The IETF BCP 47 language tag detected for a tweet's text content; corresponds to the `lang` field returned by the X v2 API."@en ;
    skos:example "en", "fr", "es" .

# X user identification
x:author_id a owl:DatatypeProperty ;
    rdfs:label "author id"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The unique numeric identifier of a user account on the X platform; corresponds to the `author_id` field returned on tweet objects by the X v2 API."@en ;
    skos:example "1752407607820607488" .

# Public engagement metrics counts
x:retweet_count a owl:DatatypeProperty ;
    rdfs:label "retweet count"@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of times a tweet has been retweeted, as exposed by the X v2 `public_metrics.retweet_count` field."@en ;
    skos:example "0", "42" .

x:reply_count a owl:DatatypeProperty ;
    rdfs:label "reply count"@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of replies to a tweet, as exposed by the X v2 `public_metrics.reply_count` field."@en ;
    skos:example "0", "3" .

x:like_count a owl:DatatypeProperty ;
    rdfs:label "like count"@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of likes received by a tweet, as exposed by the X v2 `public_metrics.like_count` field."@en ;
    skos:example "1", "127" .

x:quote_count a owl:DatatypeProperty ;
    rdfs:label "quote count"@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of quote tweets referencing this tweet, as exposed by the X v2 `public_metrics.quote_count` field."@en ;
    skos:example "0", "5" .

x:bookmark_count a owl:DatatypeProperty ;
    rdfs:label "bookmark count"@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of times a tweet has been bookmarked, as exposed by the X v2 `public_metrics.bookmark_count` field."@en ;
    skos:example "0", "8" .

x:impression_count a owl:DatatypeProperty ;
    rdfs:label "impression count"@en ;
    rdfs:domain x:TweetPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of times a tweet has been viewed by users, as exposed by the X v2 `public_metrics.impression_count` field."@en ;
    skos:example "37", "210" .

# Search query parameters (mirroring the search_recent_tweets cache key fields)
x:query_string a owl:DatatypeProperty ;
    rdfs:label "query string"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "The X v2 search query expression (1-4096 chars) submitted as the `query` parameter to GET /2/tweets/search/recent."@en ;
    skos:example "(from:TwitterDev OR from:TwitterAPI) has:media -is:retweet" .

x:start_time a owl:DatatypeProperty ;
    rdfs:label "start time"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:dateTime ;
    skos:definition "The oldest UTC timestamp (inclusive) bounding the search window, sent as the `start_time` parameter."@en ;
    skos:example "2026-05-26T00:00:00Z" .

x:end_time a owl:DatatypeProperty ;
    rdfs:label "end time"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:dateTime ;
    skos:definition "The newest UTC timestamp (exclusive) bounding the search window, sent as the `end_time` parameter."@en ;
    skos:example "2026-06-02T00:00:00Z" .

x:since_id a owl:DatatypeProperty ;
    rdfs:label "since id"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Lower-exclusive tweet-id bound: only tweets with an id greater than this value are returned."@en ;
    skos:example "2061855239876333873" .

x:until_id a owl:DatatypeProperty ;
    rdfs:label "until id"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Upper-exclusive tweet-id bound: only tweets with an id less than this value are returned."@en ;
    skos:example "2061859064825446876" .

x:max_results a owl:DatatypeProperty ;
    rdfs:label "max results"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:integer ;
    skos:definition "Maximum number of tweets to return per page (10-100) when querying GET /2/tweets/search/recent."@en ;
    skos:example "100" .

x:sort_order a owl:DatatypeProperty ;
    rdfs:label "sort order"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Sort order requested for returned tweets: either 'recency' or 'relevancy'."@en ;
    skos:example "recency", "relevancy" .

x:max_pages a owl:DatatypeProperty ;
    rdfs:label "max pages"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:integer ;
    skos:definition "Maximum number of result pages to fetch from the X v2 endpoint during a single search process."@en ;
    skos:example "1", "5" .

x:tweet_fields a owl:DatatypeProperty ;
    rdfs:label "tweet fields"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Comma-joined list of fields to include on each Tweet object, sent as the `tweet.fields` parameter."@en ;
    skos:example "created_at,author_id,public_metrics,lang" .

x:expansions a owl:DatatypeProperty ;
    rdfs:label "expansions"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Comma-joined list of object expansions to apply, sent as the `expansions` parameter."@en ;
    skos:example "author_id,referenced_tweets.id" .

x:media_fields a owl:DatatypeProperty ;
    rdfs:label "media fields"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Comma-joined list of fields on expanded Media objects, sent as the `media.fields` parameter."@en ;
    skos:example "url,preview_image_url,type" .

x:poll_fields a owl:DatatypeProperty ;
    rdfs:label "poll fields"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Comma-joined list of fields on expanded Poll objects, sent as the `poll.fields` parameter."@en ;
    skos:example "options,voting_status,end_datetime" .

x:user_fields a owl:DatatypeProperty ;
    rdfs:label "user fields"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Comma-joined list of fields on expanded User objects, sent as the `user.fields` parameter."@en ;
    skos:example "username,name,verified" .

x:place_fields a owl:DatatypeProperty ;
    rdfs:label "place fields"@en ;
    rdfs:domain x:SearchQuery ;
    rdfs:range xsd:string ;
    skos:definition "Comma-joined list of fields on expanded Place objects, sent as the `place.fields` parameter."@en ;
    skos:example "country,full_name,geo" .

# Search result set identification
x:result_set_id a owl:DatatypeProperty ;
    rdfs:label "result set id"@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range xsd:string ;
    skos:definition "Short hash identifying the search result set in the local datastore; an 8-character hex digest of the sorted parameter dictionary used as the cache key and filename."@en ;
    skos:example "21dcaa8c" .

x:result_count a owl:DatatypeProperty ;
    rdfs:label "result count"@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range xsd:integer ;
    skos:definition "Number of tweets contained in the search result set."@en ;
    skos:example "100" .

x:record_count a owl:DatatypeProperty ;
    rdfs:label "record count"@en ;
    rdfs:domain x:TweetFileImport ;
    rdfs:range xsd:integer ;
    skos:definition "Number of tweet records read from the tweet dataset file and ingested into the X graph by the import process."@en ;
    skos:example "1200000" .

x:file_path a owl:DatatypeProperty ;
    rdfs:label "file path"@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range xsd:string ;
    skos:definition "Path to the JSON envelope file in object storage that persists the query, options and merged results backing this search result set."@en ;
    skos:example "x/search_recent_tweets/roland_garros_lang_en/2026-06-02T19:15:50.123456+00:00_roland_garros_lang_en.json" .

x:newest_id a owl:DatatypeProperty ;
    rdfs:label "newest id"@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range xsd:string ;
    skos:definition "Id of the most recent tweet in the result set, as exposed by the X v2 `meta.newest_id` field."@en ;
    skos:example "2064652453870530755" .

x:oldest_id a owl:DatatypeProperty ;
    rdfs:label "oldest id"@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range xsd:string ;
    skos:definition "Id of the oldest tweet in the result set, as exposed by the X v2 `meta.oldest_id` field."@en ;
    skos:example "2064651819750449572" .

x:next_token a owl:DatatypeProperty ;
    rdfs:label "next token"@en ;
    rdfs:domain x:SearchResultSet ;
    rdfs:range xsd:string ;
    skos:definition "Pagination token to retrieve the next page of results, as exposed by the X v2 `meta.next_token` field."@en ;
    skos:example "b26v89c19zqg8o3jueqhsopk6lsleh1vu10ay5rvh2e7x" .

# Tweet flags and threading metadata
x:conversation_id a owl:DatatypeProperty ;
    rdfs:label "conversation id"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "Id of the root tweet of the conversation thread this tweet belongs to; corresponds to the `conversation_id` field returned by the X v2 API."@en ;
    skos:example "2064652453870530755" .

x:reply_settings a owl:DatatypeProperty ;
    rdfs:label "reply settings"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "Who can reply to the tweet ('everyone', 'mentioned_users', 'followers', ...); corresponds to the `reply_settings` field returned by the X v2 API."@en ;
    skos:example "everyone" .

x:possibly_sensitive a owl:DatatypeProperty ;
    rdfs:label "possibly sensitive"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the tweet content may be sensitive, as flagged by the X platform via the `possibly_sensitive` field."@en ;
    skos:example "false" .

x:paid_partnership a owl:DatatypeProperty ;
    rdfs:label "paid partnership"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the tweet is flagged as paid-partnership content via the `paid_partnership` field."@en ;
    skos:example "false" .

x:card_uri a owl:DatatypeProperty ;
    rdfs:label "card uri"@en ;
    rdfs:domain x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "URI of the link-preview card attached to the tweet; corresponds to the `card_uri` field returned by the X v2 API."@en ;
    skos:example "https://t.co/EzUWbYROqa" .

# X user profile fields (from the X v2 expanded User object)
x:username a owl:DatatypeProperty ;
    rdfs:label "username"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The unique handle of the X user account (without the @ prefix); corresponds to the `username` field of the X v2 User object."@en ;
    skos:example "turdefcom" .

x:user_name a owl:DatatypeProperty ;
    rdfs:label "user display name"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The display name of the X user account; corresponds to the `name` field of the X v2 User object."@en ;
    skos:example "TurDef" .

x:user_description a owl:DatatypeProperty ;
    rdfs:label "user description"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The profile bio of the X user account; corresponds to the `description` field of the X v2 User object."@en ;
    skos:example "Turkish Defence News" .

x:user_location a owl:DatatypeProperty ;
    rdfs:label "user location"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The free-form location declared on the X user profile; corresponds to the `location` field of the X v2 User object."@en ;
    skos:example "Aziziye Mah. Çankaya Ankara" .

x:user_url a owl:DatatypeProperty ;
    rdfs:label "user url"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The website URL declared on the X user profile; corresponds to the `url` field of the X v2 User object."@en ;
    skos:example "https://t.co/abc123" .

x:user_created_at a owl:DatatypeProperty ;
    rdfs:label "user created at"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:dateTime ;
    skos:definition "The UTC timestamp at which the X user account was created; corresponds to the `created_at` field of the X v2 User object."@en ;
    skos:example "2020-12-09T09:12:59.000Z" .

x:verified a owl:DatatypeProperty ;
    rdfs:label "verified"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the X user account is verified; corresponds to the `verified` field of the X v2 User object."@en ;
    skos:example "true" .

x:verified_type a owl:DatatypeProperty ;
    rdfs:label "verified type"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The verification type of the X user account ('blue', 'business', 'government', 'none'); corresponds to the `verified_type` field of the X v2 User object."@en ;
    skos:example "blue" .

x:protected a owl:DatatypeProperty ;
    rdfs:label "protected"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the X user account's tweets are protected (private); corresponds to the `protected` field of the X v2 User object."@en ;
    skos:example "false" .

x:parody a owl:DatatypeProperty ;
    rdfs:label "parody"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the X user account is self-declared as a parody account; corresponds to the `parody` field of the X v2 User object."@en ;
    skos:example "false" .

x:is_identity_verified a owl:DatatypeProperty ;
    rdfs:label "is identity verified"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the identity of the X user account holder has been verified by X; corresponds to the `is_identity_verified` field of the X v2 User object."@en ;
    skos:example "false" .

x:subscription_type a owl:DatatypeProperty ;
    rdfs:label "subscription type"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "The X premium subscription tier of the user account; corresponds to the `subscription_type` field of the X v2 User object."@en ;
    skos:example "Premium" .

x:profile_image_url a owl:DatatypeProperty ;
    rdfs:label "profile image url"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "URL of the profile image of the X user account; corresponds to the `profile_image_url` field of the X v2 User object."@en ;
    skos:example "https://pbs.twimg.com/profile_images/.../photo.jpg" .

x:profile_banner_url a owl:DatatypeProperty ;
    rdfs:label "profile banner url"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "URL of the profile banner image of the X user account; corresponds to the `profile_banner_url` field of the X v2 User object."@en ;
    skos:example "https://pbs.twimg.com/profile_banners/..." .

x:pinned_tweet_id a owl:DatatypeProperty ;
    rdfs:label "pinned tweet id"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "Id of the tweet pinned on the X user profile; corresponds to the `pinned_tweet_id` field of the X v2 User object."@en ;
    skos:example "2030437507402415130" .

x:most_recent_tweet_id a owl:DatatypeProperty ;
    rdfs:label "most recent tweet id"@en ;
    rdfs:domain x:XUser ;
    rdfs:range xsd:string ;
    skos:definition "Id of the most recent tweet posted by the X user account; corresponds to the `most_recent_tweet_id` field of the X v2 User object."@en ;
    skos:example "2064652453870530755" .

# X user public metrics counts
x:followers_count a owl:DatatypeProperty ;
    rdfs:label "followers count"@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of followers of the X user account, as exposed by the X v2 `public_metrics.followers_count` field on User objects."@en ;
    skos:example "7309" .

x:following_count a owl:DatatypeProperty ;
    rdfs:label "following count"@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of accounts the X user follows, as exposed by the X v2 `public_metrics.following_count` field on User objects."@en ;
    skos:example "2591" .

x:user_tweet_count a owl:DatatypeProperty ;
    rdfs:label "user tweet count"@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of tweets posted by the X user account, as exposed by the X v2 `public_metrics.tweet_count` field on User objects."@en ;
    skos:example "7080" .

x:listed_count a owl:DatatypeProperty ;
    rdfs:label "listed count"@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of public lists the X user account appears on, as exposed by the X v2 `public_metrics.listed_count` field on User objects."@en ;
    skos:example "89" .

x:user_like_count a owl:DatatypeProperty ;
    rdfs:label "user like count"@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of tweets liked by the X user account, as exposed by the X v2 `public_metrics.like_count` field on User objects."@en ;
    skos:example "810" .

x:user_media_count a owl:DatatypeProperty ;
    rdfs:label "user media count"@en ;
    rdfs:domain x:XUserPublicMetrics ;
    rdfs:range xsd:integer ;
    skos:definition "The number of media items posted by the X user account, as exposed by the X v2 `public_metrics.media_count` field on User objects."@en ;
    skos:example "1915" .

# Media fields
x:media_key a owl:DatatypeProperty ;
    rdfs:label "media key"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:string ;
    skos:definition "The unique key of a media artifact on the X platform; corresponds to the `media_key` field of the X v2 Media object."@en ;
    skos:example "13_2063731151118766080" .

x:media_type a owl:DatatypeProperty ;
    rdfs:label "media type"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:string ;
    skos:definition "The kind of media artifact ('photo', 'video', 'animated_gif'); corresponds to the `type` field of the X v2 Media object."@en ;
    skos:example "video" .

x:media_url a owl:DatatypeProperty ;
    rdfs:label "media url"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:string ;
    skos:definition "Direct URL of the media content (photos); corresponds to the `url` field of the X v2 Media object."@en ;
    skos:example "https://pbs.twimg.com/media/abc.jpg" .

x:preview_image_url a owl:DatatypeProperty ;
    rdfs:label "preview image url"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:string ;
    skos:definition "URL of the static preview image of a video or animated gif; corresponds to the `preview_image_url` field of the X v2 Media object."@en ;
    skos:example "https://pbs.twimg.com/amplify_video_thumb/.../img/abc.jpg" .

x:media_width a owl:DatatypeProperty ;
    rdfs:label "media width"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:integer ;
    skos:definition "Width of the media artifact in pixels; corresponds to the `width` field of the X v2 Media object."@en ;
    skos:example "1920" .

x:media_height a owl:DatatypeProperty ;
    rdfs:label "media height"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:integer ;
    skos:definition "Height of the media artifact in pixels; corresponds to the `height` field of the X v2 Media object."@en ;
    skos:example "1080" .

x:duration_ms a owl:DatatypeProperty ;
    rdfs:label "duration ms"@en ;
    rdfs:domain x:Media ;
    rdfs:range xsd:integer ;
    skos:definition "Duration of a video or animated gif in milliseconds; corresponds to the `duration_ms` field of the X v2 Media object."@en ;
    skos:example "69149" .

# Context annotation fields
x:context_domain_id a owl:DatatypeProperty ;
    rdfs:label "context domain id"@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range xsd:string ;
    skos:definition "Id of the classification domain of a context annotation; corresponds to `context_annotations[].domain.id` in the X v2 API."@en ;
    skos:example "88" .

x:context_domain_name a owl:DatatypeProperty ;
    rdfs:label "context domain name"@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range xsd:string ;
    skos:definition "Name of the classification domain of a context annotation; corresponds to `context_annotations[].domain.name` in the X v2 API."@en ;
    skos:example "Political Body" .

x:context_domain_description a owl:DatatypeProperty ;
    rdfs:label "context domain description"@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range xsd:string ;
    skos:definition "Description of the classification domain of a context annotation; corresponds to `context_annotations[].domain.description` in the X v2 API."@en ;
    skos:example "A section of a government, like The Supreme Court" .

x:context_entity_id a owl:DatatypeProperty ;
    rdfs:label "context entity id"@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range xsd:string ;
    skos:definition "Id of the entity recognized by a context annotation; corresponds to `context_annotations[].entity.id` in the X v2 API."@en ;
    skos:example "1016738021939351558" .

x:context_entity_name a owl:DatatypeProperty ;
    rdfs:label "context entity name"@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range xsd:string ;
    skos:definition "Name of the entity recognized by a context annotation; corresponds to `context_annotations[].entity.name` in the X v2 API."@en ;
    skos:example "North Atlantic Treaty Organization" .

x:context_entity_description a owl:DatatypeProperty ;
    rdfs:label "context entity description"@en ;
    rdfs:domain x:ContextAnnotation ;
    rdfs:range xsd:string ;
    skos:definition "Description of the entity recognized by a context annotation; corresponds to `context_annotations[].entity.description` in the X v2 API."@en ;
    skos:example "North Atlantic Treaty Organization" .

# Tweet URL entity fields
x:url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:domain x:TweetUrl, x:Tweet ;
    rdfs:range xsd:string ;
    skos:definition "A URL associated with the subject. On a Tweet URL entity, the shortened t.co URL as it appears in the tweet text (`entities.urls[].url` in the X v2 API). On a Tweet, the canonical permalink to the tweet, reconstructed as `https://x.com/<author_id>/status/<id>` since the X v2 API does not return it directly."@en ;
    skos:example "https://t.co/EzUWbYROqa", "https://x.com/1752407607820607488/status/2061859064825446876" .

x:expanded_url a owl:DatatypeProperty ;
    rdfs:label "expanded url"@en ;
    rdfs:domain x:TweetUrl ;
    rdfs:range xsd:string ;
    skos:definition "The fully resolved destination URL; corresponds to `entities.urls[].expanded_url` in the X v2 API."@en ;
    skos:example "https://turdef.com/article/efes-2026-turkiye-to-nato-or-nato-to-turkiye" .

x:display_url a owl:DatatypeProperty ;
    rdfs:label "display url"@en ;
    rdfs:domain x:TweetUrl ;
    rdfs:range xsd:string ;
    skos:definition "The truncated URL as displayed in the tweet; corresponds to `entities.urls[].display_url` in the X v2 API."@en ;
    skos:example "turdef.com/article/efes-2…" .

x:unwound_url a owl:DatatypeProperty ;
    rdfs:label "unwound url"@en ;
    rdfs:domain x:TweetUrl ;
    rdfs:range xsd:string ;
    skos:definition "The final unrolled URL after following redirects; corresponds to `entities.urls[].unwound_url` in the X v2 API."@en ;
    skos:example "https://turdef.com/article/efes-2026-turkiye-to-nato-or-nato-to-turkiye" .

x:url_title a owl:DatatypeProperty ;
    rdfs:label "url title"@en ;
    rdfs:domain x:TweetUrl ;
    rdfs:range xsd:string ;
    skos:definition "The HTML title of the linked page; corresponds to `entities.urls[].title` in the X v2 API."@en ;
    skos:example "EFES 2026: Turkiye to NATO? or NATO to Turkiye? / Chapter-I" .

x:url_description a owl:DatatypeProperty ;
    rdfs:label "url description"@en ;
    rdfs:domain x:TweetUrl ;
    rdfs:range xsd:string ;
    skos:definition "The HTML meta description of the linked page; corresponds to `entities.urls[].description` in the X v2 API."@en ;
    skos:example "The Turkish Armed Forces completed the Efes 2026 Exercise." .
