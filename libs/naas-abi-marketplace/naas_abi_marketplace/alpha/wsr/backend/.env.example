# WSR FastAPI — environment variables
# Copy to .env and fill in values

# ── OpenSky Network ───────────────────────────────────────────────────────────
# New accounts (created after mid-March 2025) use OAuth2 client credentials.
# Log in → Account page → "Create API client" → copy client_id + client_secret.
# Docs: https://openskynetwork.github.io/opensky-api/rest.html
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Legacy basic-auth (pre-March 2025 accounts only — being deprecated by OpenSky).
# Leave blank if using OAuth2 above.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Transport for London (TfL) JamCam ────────────────────────────────────────
# Optional — increases rate limit from 60 to 500 req/min.
# Free registration: https://api-portal.tfl.gov.uk/signup
# Without a key the adapter still fetches all ~900 London cameras,
# but may hit rate limits if the backend restarts frequently.
TFL_APP_KEY=

# ── OpenWebcamDB ──────────────────────────────────────────────────────────────
# Optional — disables /api/webcams and OWDB cameras in /api/cctv if absent.
OPENWEBCAMDB_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed browser origins.
ALLOWED_ORIGINS=["*"]
