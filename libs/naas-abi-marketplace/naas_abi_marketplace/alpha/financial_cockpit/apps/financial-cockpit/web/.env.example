# financial-cockpit — local template env. Copy to .env (the kickstart CLI does
# this for you: `npm run kickstart`).

# ── Data source selector ───────────────────────────────────────────────────
#   ENV unset  -> read datasets from the local ./data directory (default)
#   ENV=prod   -> read datasets from the Cloudflare R2 bucket (Workers only)
# ENV=prod

# Local datastore root, relative to the web app. Ships with demo data in ./data.
DATA_LOCAL_ROOT=./data

# Maps datastore-relative keys to R2 object keys (globals/x -> data/globals/x).
R2_DATA_PREFIX=data

# ── Auth (local template = shared demo password, no e-mail service) ─────────
# Signs the session cookie (JWT). MUST be set — the app 500s without it.
# The kickstart CLI generates a random value.
SESSION_SECRET=change-me-to-a-long-random-string

# Shared demo password: entering it on /login grants a full-access admin
# session. Leave unset to disable sign-in entirely.
ADMIN_PASSWORD=demo

# ── R2 push (optional — used by scripts/push_to_r2.py to seed a prod bucket) ─
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=app-financial-cockpit
