@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix abi: <http://ontology.naas.ai/abi/> .
@prefix doc: <http://ontology.naas.ai/abi/document/> .

<http://ontology.naas.ai/abi/DocumentOntology> a owl:Ontology ;
    owl:imports <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.ttl> ;
    dc:title "Document Ontology"@en ;
    dc:description "Ontology for documents."@en ;
    dc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Ontology for documents."@en ;
    dc11:contributor "Florent Ravenel", "Jeremy Ravenel", "Maxime Jublou" ;
    dc11:date "2026-04-07"^^xsd:date .

#################################################################
#    Classes
#################################################################

doc:File a owl:Class ;
    rdfs:label "File"@en ;
    skos:definition "A File is a physical or digital file that contains information."@en ;
    skos:example "A PDF file, a Word document, or a spreadsheet."@en ;
    rdfs:subClassOf bfo:BFO_0000031,
    [ a owl:Restriction ;
        owl:onProperty doc:embodies ;
        owl:someValuesFrom doc:Document
    ] ,
    [ a owl:Restriction ;
        owl:onProperty doc:embodies ;
        owl:allValuesFrom doc:Document
    ] .

doc:Document a owl:Class ;
    rdfs:label "Document"@en ;
    skos:definition "A Document is a semantic, meaning-bearing artifact intended for interpretation, such as a textual record, form, certificate, or digitally encoded contract."@en ;
    skos:example "An employment contract in PDF format, a university diploma as a scanned image, or a digitally-signed XML invoice."@en ;
    rdfs:subClassOf bfo:BFO_0000031,
    [ a owl:Restriction ;
        owl:onProperty doc:isEmbodiedIn ;
        owl:someValuesFrom doc:File
    ] ,
    [ a owl:Restriction ;
        owl:onProperty doc:isEmbodiedIn ;
        owl:allValuesFrom doc:File
    ] .

#################################################################
#    Object Properties
#################################################################

doc:embodies a owl:ObjectProperty ;
    rdfs:domain doc:File ;
    rdfs:range doc:Document ;
    rdfs:label "embodies" ;
    skos:definition "A file embodies a document."@en ;
    skos:example "The file 'employment_contract.pdf' embodies the document 'Employment Contract'."@en .

doc:isEmbodiedIn a owl:ObjectProperty ;
    owl:inverseOf doc:embodies ;
    rdfs:domain doc:Document ;
    rdfs:range doc:File ;
    skos:definition "A document is embodied in a file."@en ;
    skos:example "The document 'Employment Contract' is embodied in the file 'employment_contract.pdf'."@en .

#################################################################
#    Data Properties
#################################################################

doc:path a owl:DatatypeProperty ;
    rdfs:label "file path"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:string ;
    skos:definition "The path of the document."@en ;
    skos:example "The path of the document is '/documents/document.pdf'."@en .

doc:name a owl:DatatypeProperty ;
    rdfs:label "file name"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:string ;
    skos:definition "The name of the document."@en ;
    skos:example "The name of the document is 'document.pdf'."@en .

doc:mime_type a owl:DatatypeProperty ;
    rdfs:label "mime type"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:string ;
    skos:definition "The MIME type of the document."@en ;
    skos:example "The MIME type of the document is 'application/pdf'."@en .

doc:file_size_bytes a owl:DatatypeProperty ;
    rdfs:label "file size bytes"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:integer ;
    skos:definition "The size of the document in bytes."@en ;
    skos:example "The size of the document is '3804'."@en .

doc:created_time a owl:DatatypeProperty ;
    rdfs:label "created time"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:dateTime ;
    skos:definition "The created timestamp of the document."@en ;
    skos:example "The created time of the document is '2026-04-07T16:14:13.411024'."@en .

doc:modified_time a owl:DatatypeProperty ;
    rdfs:label "modified time"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:dateTime ;
    skos:definition "The last modified timestamp of the document."@en ;
    skos:example "The modified time of the document is '2026-04-07T16:14:13.411024'."@en .

doc:accessed_time a owl:DatatypeProperty ;
    rdfs:label "accessed time"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:dateTime ;
    skos:definition "The last accessed timestamp of the document."@en ;
    skos:example "The accessed time of the document is '2026-04-07T16:14:13.492697'."@en .

doc:is_file a owl:DatatypeProperty ;
    rdfs:label "is file"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:boolean ;
    skos:definition "True if the path points to a file."@en ;
    skos:example "The document is a file: 'true'."@en .

doc:is_directory a owl:DatatypeProperty ;
    rdfs:label "is directory"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:boolean ;
    skos:definition "True if the path points to a directory."@en ;
    skos:example "The document is a directory: 'false'."@en .

doc:permissions a owl:DatatypeProperty ;
    rdfs:label "permissions"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:string ;
    skos:definition "The file permissions of the document in Unix-like notation."@en ;
    skos:example "The permissions of the document are '-rw-r--r--'."@en .

doc:encoding a owl:DatatypeProperty ;
    rdfs:label "encoding"@en ;
    rdfs:domain doc:File ;
    rdfs:range xsd:string ;
    skos:definition "The detected character encoding of the document when applicable."@en ;
    skos:example "The encoding of the document is 'utf-8'."@en .

doc:md5 a owl:DatatypeProperty ;
    rdfs:label "md5"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The MD5 checksum (hex) of the document content."@en ;
    skos:example "The md5 checksum of the document is '380cb2acdf4b2fc233371bd9db7cf185'."@en .

doc:sha1 a owl:DatatypeProperty ;
    rdfs:label "sha1"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The SHA-1 checksum (hex) of the document content."@en ;
    skos:example "The sha1 checksum of the document is '9b5011bf5359305c9590fd5ec67f23b4bafc8a92'."@en .

doc:sha256 a owl:DatatypeProperty ;
    rdfs:label "sha256"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The SHA-256 checksum (hex) of the document content."@en ;
    skos:example "The sha256 checksum of the document is '9dd332e7d9bb894763ffe97bc4f6d88d79fc44ed4ec317359dec8fc7fb755c6f'."@en .

doc:content a owl:DatatypeProperty ;
    rdfs:label "content"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The textual content of the document (when extracted or provided)."@en ;
    skos:example "The content of the document is 'This Employment Contract is made between...'"@en .
    
doc:title a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The title of the document."@en ;
    skos:example "The title of the document is 'Employment Contract'."@en .

doc:author a owl:DatatypeProperty ;
    rdfs:label "author"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The author of the document."@en ;
    skos:example "The author of the document is 'Jane Doe'."@en .

doc:language a owl:DatatypeProperty ;
    rdfs:label "language"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The language of the document content."@en ;
    skos:example "The language of the document is 'en'."@en .

doc:creation_date a owl:DatatypeProperty ;
    rdfs:label "creation date"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:dateTime ;
    skos:definition "The creation date of the document (when available from document-level metadata)."@en ;
    skos:example "The creation date of the document is '2026-04-07T16:14:13.411024'."@en .

doc:subject a owl:DatatypeProperty ;
    rdfs:label "subject"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "The subject of the document."@en ;
    skos:example "The subject of the document is 'Human Resources'."@en .

doc:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "A short description or abstract of the document."@en ;
    skos:example "The description of the document is 'Signed employment contract for 2026'."@en .

doc:keywords a owl:DatatypeProperty ;
    rdfs:label "keywords"@en ;
    rdfs:domain doc:Document ;
    rdfs:range xsd:string ;
    skos:definition "Keywords associated with the document (typically a comma-separated list)."@en ;
    skos:example "The keywords of the document are 'contract, employment, HR'."@en .