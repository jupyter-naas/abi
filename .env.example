# Environment Variables Configuration File
#
# This is a template file (.env.example) that shows all available environment variables
# used by the ABI system. To use it:
# 1. Copy this file to .env
# 2. Replace placeholder values with your actual credentials
# 3. Uncomment (remove #) from lines you want to activate
#
# Note: The .env file should never be committed to version control
# as it contains sensitive credentials

ENV=dev
LOG_LEVEL=ERROR

# ABI API Configuration
# Create and add your API key in the GitHub project settings. This key is used to authenticate requests to the ABI API.
#ABI_API_KEY=1234567890

# OpenAI API Configuration
# Get your API key at: https://platform.openai.com/api-keys
#OPENAI_API_KEY=your_openai_api_key_here

# Naas API Configuration
# Get your API key at: https://naas.ai/account/api-key
#NAAS_API_KEY=your_naas_api_key_here

# Public ingress / reverse proxy configuration
#PUBLIC_WEB_HOST=localhost
#PUBLIC_API_HOST=api.localhost
#NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# AWS Neptune Configuration
# USE_AWS_NEPTUNE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# AWS_NEPTUNE_DB_INSTANCE_IDENTIFIER=db-neptune-1-instance-1

# Neptune Bastion host
# AWS_BASTION_HOST=35.87.174.56
# AWS_BASTION_PORT=22
# AWS_BASTION_USER=ec2-user
# AWS_BASTION_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
# ...
# ...
# -----END OPENSSH PRIVATE KEY-----

# Vector Store Configuration
# Supported adapters: qdrant
#VECTOR_STORE_ADAPTER=qdrant

# Qdrant Configuration
#QDRANT_HOST=localhost
#QDRANT_PORT=6333
#QDRANT_API_KEY=your_qdrant_api_key_here
#QDRANT_HTTPS=false
#QDRANT_TIMEOUT=30

# -----------------------------------------------------------------------------
# Local admin credentials (used only for local development)
# These seed a built-in admin account on first stack start.
# Change before any public/shared deployment.
# Login at: http://localhost:3042/auth/login
# -----------------------------------------------------------------------------
#NEXUS_USER_ADMIN_EMAIL=admin@example.com
#NEXUS_USER_ADMIN_PASSWORD=Admin1234!

# Default workspace slug used when the browser has no last-visited-workspace cookie.
# REQUIRED in production: set this to your workspace slug or the app will fall back to "primary"
# and may redirect to a 404 on first visit.
# After first login the browser remembers the last visited workspace, so this only affects
# the very first visit and any session where the cookie has expired.
# See: docs/architecture/adr/adr-001-workspace-routing.md
#NEXUS_DEFAULT_WORKSPACE=primary
