# Environment Variables Configuration File
#
# This is a template file (.env.example) that shows all available environment variables
# used by the ABI system. To use it:
# 1. Copy this file to .env
# 2. Fill in your credentials in the "Required" section below
# 3. The infrastructure defaults in the lower section can be left as-is for local dev
#
# Note: The .env file should never be committed to version control
# as it contains sensitive credentials

ENV=dev
LOG_LEVEL=ERROR

# =============================================================================
# REQUIRED: fill these before running `abi start`
# =============================================================================

# OpenAI API key - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Naas API key - https://naas.ai/account/api-key
NAAS_API_KEY=your_naas_api_key_here

# GitHub personal access token (needs repo scope) - https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=your_github_token_here

# OpenRouter API key (optional but recommended) - https://openrouter.ai/keys
#OPENROUTER_API_KEY=your_openrouter_api_key_here

# Local admin account - login at http://localhost:3042/auth/login
# The seed code keys off the email-derived variable name (ADMIN_EXAMPLE_COM for admin@example.com)
NEXUS_USER_ADMIN_EMAIL=admin@example.com
NEXUS_USER_ADMIN_PASSWORD=Admin1234!
NEXUS_USER_ADMIN_EXAMPLE_COM_EMAIL=admin@example.com
NEXUS_USER_ADMIN_EXAMPLE_COM_PASSWORD=Admin1234!

# =============================================================================
# INFRASTRUCTURE: auto-generated on first setup, change for production
# =============================================================================

# Internal API key for service-to-service auth (generate with: python3 -c "import uuid; print(uuid.uuid4())")
ABI_API_KEY=change-me-to-a-uuid

POSTGRES_USER=abi
POSTGRES_PASSWORD=change-me-to-a-uuid
POSTGRES_DB=nexus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

QDRANT_HOST=qdrant
QDRANT_PORT=6333

REDIS_HOST=redis
REDIS_PORT=6379

MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=abi
MINIO_ROOT_PASSWORD=change-me-to-a-uuid

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=abi
RABBITMQ_PASSWORD=change-me-to-a-uuid

FUSEKI_ADMIN_PASSWORD=change-me-to-a-uuid

ABI_HOST=abi
PUBLIC_WEB_HOST=localhost
PUBLIC_API_HOST=api.localhost
NEXUS_WEB_PORT=3042
NEXUS_API_URL=http://abi:9879

# =============================================================================
# OPTIONAL
# =============================================================================

# Default workspace slug. REQUIRED in production to avoid 404 on first visit.
# See: docs/site/docs/updates/20260513_workspace-routing.md
#NEXUS_DEFAULT_WORKSPACE=primary

# Public ingress override (for custom domains in production)
#NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# AWS Neptune (alternative graph backend)
# USE_AWS_NEPTUNE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# AWS_NEPTUNE_DB_INSTANCE_IDENTIFIER=db-neptune-1-instance-1

# Neptune bastion host
# AWS_BASTION_HOST=35.87.174.56
# AWS_BASTION_PORT=22
# AWS_BASTION_USER=ec2-user
# AWS_BASTION_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
# ...
# -----END OPENSSH PRIVATE KEY-----

# Qdrant extra config (for remote/cloud Qdrant)
#QDRANT_API_KEY=your_qdrant_api_key_here
#QDRANT_HTTPS=false
#QDRANT_TIMEOUT=30
