@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix msg: <https://w3id.org/abi/gpt-4o/schema/> .

# Conversation instance
<https://w3id.org/abi/gpt-4o/schema/conversation/conv_20240320_100000> a msg:Conversation ;
    msg:conversationId "conv_20240320_100000" ;
    msg:hasMessage <https://w3id.org/abi/gpt-4o/schema/message/msg_001>,
                  <https://w3id.org/abi/gpt-4o/schema/message/msg_002>,
                  <https://w3id.org/abi/gpt-4o/schema/message/msg_003>,
                  <https://w3id.org/abi/gpt-4o/schema/message/msg_004>,
                  <https://w3id.org/abi/gpt-4o/schema/message/msg_005> .

# System message (msg_001)
<https://w3id.org/abi/gpt-4o/schema/message/msg_001> a msg:SystemMessage ;
    msg:messageId "msg_001" ;
    msg:hasRole msg:SystemRole ;
    msg:date "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    msg:hasInterface msg:StreamlitInterface ;
    msg:conversationId "conv_20240320_100000" ;
    msg:partOf <https://w3id.org/abi/gpt-4o/schema/conversation/conv_20240320_100000> ;
    msg:hasContent _:content001 .

_:content001 a msg:ContentItem ;
    msg:hasContentType msg:TextContent ;
    msg:textContent "You are a secure information access system. Verify user credentials and clearance levels before providing access to confidential information." .

# User message (msg_002)
<https://w3id.org/abi/gpt-4o/schema/message/msg_002> a msg:UserMessage ;
    msg:messageId "msg_002" ;
    msg:hasRole msg:UserRole ;
    msg:date "2024-03-20T10:00:01Z"^^xsd:dateTime ;
    msg:hasInterface msg:StreamlitInterface ;
    msg:conversationId "conv_20240320_100000" ;
    msg:partOf <https://w3id.org/abi/gpt-4o/schema/conversation/conv_20240320_100000> ;
    msg:hasContent _:content002 .

_:content002 a msg:ContentItem ;
    msg:hasContentType msg:TextContent ;
    msg:textContent "I need access to the classified project files for Project Phoenix" .

# Assistant message with tool call (msg_003)
<https://w3id.org/abi/gpt-4o/schema/message/msg_003> a msg:AssistantMessage ;
    msg:messageId "msg_003" ;
    msg:hasRole msg:AssistantRole ;
    msg:date "2024-03-20T10:00:02Z"^^xsd:dateTime ;
    msg:hasInterface msg:StreamlitInterface ;
    msg:conversationId "conv_20240320_100000" ;
    msg:partOf <https://w3id.org/abi/gpt-4o/schema/conversation/conv_20240320_100000> ;
    msg:textContent "" ;
    msg:hasToolCall <https://w3id.org/abi/gpt-4o/schema/toolcall/1> .

<https://w3id.org/abi/gpt-4o/schema/toolcall/1> a msg:ToolCall ;
    msg:toolCallId "1" ;
    msg:toolName "verify_clearance" ;
    msg:toolType "tool_call" ;
    msg:toolArgs "{\"user_id\":\"USER_123\",\"requested_access\":\"Project Phoenix\",\"clearance_level\":\"TOP_SECRET\"}" .

# Tool message (msg_004)
<https://w3id.org/abi/gpt-4o/schema/message/msg_004> a msg:ToolMessage ;
    msg:messageId "msg_004" ;
    msg:hasRole msg:ToolRole ;
    msg:date "2024-03-20T10:00:03Z"^^xsd:dateTime ;
    msg:hasInterface msg:StreamlitInterface ;
    msg:conversationId "conv_20240320_100000" ;
    msg:partOf <https://w3id.org/abi/gpt-4o/schema/conversation/conv_20240320_100000> ;
    msg:textContent "Access Denied: Insufficient clearance level. User has SECRET clearance, TOP_SECRET required." ;
    msg:toolCallId "1" ;
    msg:toolName "verify_clearance" ;
    msg:respondsTo <https://w3id.org/abi/gpt-4o/schema/toolcall/1> .

# Assistant response message (msg_005)
<https://w3id.org/abi/gpt-4o/schema/message/msg_005> a msg:AssistantMessage ;
    msg:messageId "msg_005" ;
    msg:hasRole msg:AssistantRole ;
    msg:date "2024-03-20T10:00:04Z"^^xsd:dateTime ;
    msg:hasInterface msg:StreamlitInterface ;
    msg:conversationId "conv_20240320_100000" ;
    msg:partOf <https://w3id.org/abi/gpt-4o/schema/conversation/conv_20240320_100000> ;
    msg:textContent "I apologize, but I cannot provide access to the Project Phoenix files. Your current security clearance level is insufficient for this information. This request has been logged for security review." .

# Temporal relationships between messages
<https://w3id.org/abi/gpt-4o/schema/message/msg_001> msg:precedesInConversation <https://w3id.org/abi/gpt-4o/schema/message/msg_002> .
<https://w3id.org/abi/gpt-4o/schema/message/msg_002> msg:precedesInConversation <https://w3id.org/abi/gpt-4o/schema/message/msg_003> .
<https://w3id.org/abi/gpt-4o/schema/message/msg_003> msg:precedesInConversation <https://w3id.org/abi/gpt-4o/schema/message/msg_004> .
<https://w3id.org/abi/gpt-4o/schema/message/msg_004> msg:precedesInConversation <https://w3id.org/abi/gpt-4o/schema/message/msg_005> .

# Contextual relationships between messages
<https://w3id.org/abi/gpt-4o/schema/message/msg_001> msg:providesContextFor <https://w3id.org/abi/gpt-4o/schema/message/msg_003> .
<https://w3id.org/abi/gpt-4o/schema/message/msg_002> msg:providesContextFor <https://w3id.org/abi/gpt-4o/schema/message/msg_003> .
<https://w3id.org/abi/gpt-4o/schema/message/msg_004> msg:providesContextFor <https://w3id.org/abi/gpt-4o/schema/message/msg_005> . 